FROM node:20-alpine AS base
WORKDIR /app

FROM base AS deps
COPY package.json package-lock.json ./
RUN npm ci

FROM deps AS dev
EXPOSE 5173
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]

FROM deps AS build
ARG VITE_BACKEND_PROVIDER=supabase
ARG VITE_SUPABASE_URL=
ARG VITE_SUPABASE_ANON_KEY=
ARG VITE_SUPABASE_PROXY_URL=
ARG VITE_SHEET_MIRROR_GID=1772676601
ARG VITE_KROMKA_EXECUTORS=
ARG VITE_PRAS_EXECUTORS=
ENV VITE_BACKEND_PROVIDER=$VITE_BACKEND_PROVIDER
ENV VITE_SUPABASE_URL=$VITE_SUPABASE_URL
ENV VITE_SUPABASE_ANON_KEY=$VITE_SUPABASE_ANON_KEY
ENV VITE_SUPABASE_PROXY_URL=$VITE_SUPABASE_PROXY_URL
ENV VITE_SHEET_MIRROR_GID=$VITE_SHEET_MIRROR_GID
ENV VITE_KROMKA_EXECUTORS=$VITE_KROMKA_EXECUTORS
ENV VITE_PRAS_EXECUTORS=$VITE_PRAS_EXECUTORS
COPY . .
RUN npm run build

FROM nginx:1.27-alpine AS runtime
COPY nginx/default.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/dist /usr/share/nginx/html
EXPOSE 80
