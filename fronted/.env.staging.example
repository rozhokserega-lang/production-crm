VITE_BACKEND_PROVIDER=supabase
# Прямой URL проекта Supabase:
# VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Если браузер не достучится до *.supabase.co (блокировка), укажите HTTPS-прокси на своём VPS:
# VITE_SUPABASE_URL=https://supabase-proxy.ВАШ-ДОМЕН
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_PUBLISHABLE_ANON_KEY

# Исполнители в UI (через запятую). Без правки кода.
# Примеры:
# VITE_KROMKA_EXECUTORS=Слава,Сережа,Иван
# VITE_PRAS_EXECUTORS=Леха,Виталик,Петр

# Опционально (legacy): дублирование части действий в Google Apps Script.
# Без этих переменных CRM работает только через Supabase.
# VITE_GAS_WEBAPP_URL=https://script.google.com/macros/s/YOUR_WEBAPP_ID/exec
# VITE_HYBRID_DUPLICATE_ACTIONS=webSetPilkaDone,webSetKromkaDone,webSetPrasDone,webSetAssemblyDone,webSetShippingDone,webSendShipmentToWork,webConsumeSheetsByOrderId
