function webGetShipmentBoard() {
  const shipment = getSheet(SHEETS.SHIPMENT);
  if (!shipment) throw new Error("Лист '" + SHEETS.SHIPMENT + "' не найден");

  const lastRow = shipment.getLastRow();
  const lastCol = shipment.getLastColumn();
  if (lastRow < 3 || lastCol < 18) return { weeks: [], sections: [] };

  const values = shipment.getRange(1, 1, lastRow, lastCol).getValues();
  const bgs = shipment.getRange(1, 1, lastRow, lastCol).getBackgrounds();
  const notes = shipment.getRange(1, 1, lastRow, lastCol).getNotes();

  const track = getSheet(SHEETS.TRACK);
  const inWorkSet = new Set();
  if (track && track.getLastRow() >= 2) {
    const td = track.getRange(2, 1, track.getLastRow() - 1, COL.LAST).getValues();
    td.forEach(r => {
      const item = String(r[COL.ITEM - 1] || "").trim();
      const material = String(getEffectiveMaterial_(item, r[COL.MATERIAL - 1]) || "").trim();
      const week = String(r[COL.WEEK - 1] || "").trim();
      if (item && week) inWorkSet.add([item, material, week].join("||"));
    });
  }

  const weeks = [];
  for (let c = 18; c <= lastCol; c++) {
    weeks.push({ col: c, week: String(values[0][c - 1] || "").trim() });
  }

  const sectionsMap = {};
  for (let r = 3; r <= lastRow; r++) {
    const item = String(values[r - 1][5] || "").trim(); // F
    if (!item) continue;
    const material = String(values[r - 1][0] || values[r - 1][6] || "").trim(); // A, fallback G
    const outputPerSheet = Number(values[r - 1][1] || 0); // B: сколько изделий с одного листа
    const availableSheets = Number(values[r - 1][4] || 0); // E: сколько листов доступно по материалу
    const materialBalanceText = String(values[r - 1][3] || "").trim(); // D: хватает/не хватает
    const materialShortage =
      /не\s*хватает/i.test(materialBalanceText) ||
      String(materialBalanceText).includes("❌");
    const section = getFurnitureGroupName_(item) || "Прочее";

    const cells = [];
    for (let c = 18; c <= lastCol; c++) {
      const qty = Number(values[r - 1][c - 1] || 0);
      const bg = String(bgs[r - 1][c - 1] || "").toLowerCase();
      const note = String(notes[r - 1][c - 1] || "");
      if (!(qty > 0) && isNeutralShipmentColor_(bg)) continue;
      const week = String(values[0][c - 1] || "").trim();
      const inWork = inWorkSet.has([item, material, week].join("||"));
      const canSendToWork = qty > 0 && isNeutralShipmentColor_(bg) && !inWork;
      const sheetsNeeded = outputPerSheet > 0 ? Math.ceil(qty / outputPerSheet) : 0;
      const materialEnoughForOrder = sheetsNeeded > 0 ? sheetsNeeded <= availableSheets : true;
      cells.push({
        col: c,
        week,
        qty,
        outputPerSheet,
        sheetsNeeded,
        availableSheets,
        materialEnoughForOrder,
        bg: bg || "#ffffff",
        note,
        inWork,
        canSendToWork,
      });
    }
    if (!cells.length) continue;

    if (!sectionsMap[section]) sectionsMap[section] = [];
    sectionsMap[section].push({
      row: r,
      item,
      material,
      materialBalanceText,
      materialShortage,
      cells,
    });
  }

  const sections = Object.keys(sectionsMap).sort().map(name => ({
    name,
    items: sectionsMap[name].sort((a, b) => String(a.item).localeCompare(String(b.item))),
  }));

  return { weeks, sections };
}

function webSendShipmentToWork(row, col) {
  return withWebLock_(function() {
    const shipment = getSheet(SHEETS.SHIPMENT);
    if (!shipment) throw new Error("Лист '" + SHEETS.SHIPMENT + "' не найден");
    const r = Number(row || 0);
    const c = Number(col || 0);
    if (!(r >= 3 && r <= shipment.getLastRow())) throw new Error("Некорректная строка");
    if (!(c >= 18 && c <= shipment.getLastColumn())) throw new Error("Некорректная колонка");

    const item = String(shipment.getRange(r, 6).getValue() || "").trim();
    const material = getShipmentMaterialFromSheetRow_(shipment, r);
    const week = String(shipment.getRange(1, c).getValue() || "").trim();
    const qty = Number(shipment.getRange(r, c).getValue() || 0);
    const bg = String(shipment.getRange(r, c).getBackground() || "").toLowerCase();

    if (!item) throw new Error("В строке нет изделия");
    if (!(qty > 0)) throw new Error("В ячейке нет количества");
    if (!isNeutralShipmentColor_(bg)) throw new Error("Отправка доступна только для ячеек без цвета");

    const track = getSheet(SHEETS.TRACK);
    if (!track) throw new Error("Лист '" + SHEETS.TRACK + "' не найден");
    const existing = findOrderRowByKey(track, item, material, week);
    if (existing !== -1) return { ok: true, skipped: true, reason: "already_exists" };

    const planMeta = fillPlanFromShipmentCell_(shipment, r, c, qty);
    sendShipmentCellToWork_(shipment, r, c);
    shipment.getRange(r, c).setBackground("#ffff00");
    shipment.getRange(r, c).setNote("📤 Отправлено в работу: " + formatMoscowDate(getMoscowTime()));
    return { ok: true, row: r, col: c, plan: planMeta, preview: readPlanPreview_() };
  });
}

