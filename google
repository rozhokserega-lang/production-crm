function consumeSheetsSubmit(row, material, qty, orderId, itemName, week) {
  const track = getSheet(SHEETS.TRACK);
  if (!track) throw new Error("Лист «" + SHEETS.TRACK + "» не найден.");
  const r = Number(row || 0);
  if (!(r >= 2 && r <= track.getLastRow())) throw new Error("Некорректная строка: " + row);

  const order = String(orderId || ensureOrderIdForRow(track, r));
  const mat = String(material || "").trim();
  const qtyNum = Number(qty || 0);
  if (!mat) throw new Error("Материал не указан.");
  if (!isFinite(qtyNum) || qtyNum <= 0) throw new Error("Некорректное количество.");

  // Защита от случайного дубля (двойной клик/повторный запрос) в коротком окне.
  const nowMs = Date.now();
  const sig = [order, mat.toLowerCase(), qtyNum].join("|");
  const prevSig = String(getScriptProp(PROP.LAST_CONSUME_SIGNATURE, false) || "");
  const prevAt = Number(getScriptProp(PROP.LAST_CONSUME_AT_MS, false) || 0);
  const DUP_WINDOW_MS = 15000;
  if (prevSig === sig && prevAt > 0 && (nowMs - prevAt) <= DUP_WINDOW_MS) {
    return { ok: true, skipped: true, reason: "duplicate_guard" };
  }

  postToMaterialsMonthlySheet_("расход", material, qty, {
    source: "sheet",
    orderId: order,
    trackRow: r,
    itemName: String(itemName || track.getRange(r, COL.ITEM).getValue() || ""),
    week: String(week || track.getRange(r, COL.WEEK).getValue() || ""),
    user: "manual"
  });
  setScriptProp(PROP.LAST_CONSUME_SIGNATURE, sig);
  setScriptProp(PROP.LAST_CONSUME_AT_MS, String(nowMs));

  // Списание выполнено — очищаем очередь "последняя пилка готово" для этой строки.
  try {
    const pending = Number(getScriptProp(PROP.PILKA_CONSUME_PENDING_ROW, false) || 0);
    if (pending === r) setScriptProp(PROP.PILKA_CONSUME_PENDING_ROW, "");
  } catch (_) {}
  try { track.getRange(r, COL.CONSUME_SHEETS).setValue(false); } catch (_) {}

  return { ok: true };
}

