function getLaborGroupName_(itemName) {
  const s = String(itemName || "").trim().toLowerCase();
  if (!s) return "";

  // Явные группы по вашему правилу
  if (s.startsWith("stabile")) return "Stabile";
  if (s.startsWith("solito2")) return "Solito2";
  if (s.startsWith("solito")) return "Solito";
  if (s.startsWith("cremona")) return "Cremona";
  if (s.startsWith("avella lite")) return "Avella lite";
  if (s.startsWith("avella")) return "Avella";
  if (s.startsWith("премьер")) return "Премьер";
  if (s.startsWith("классико+")) return "Классико +";
  if (s.startsWith("классико")) return "Классико";
  if (s.startsWith("donini grande")) return "Donini Grande";
  if (s.startsWith("donini r 750")) return "Donini R 750";
  if (s.startsWith("donini r 806")) return "Donini R 806";
  if (s.startsWith("donini r")) return "Donini R";
  if (s.startsWith("donini")) return "Donini";
  if (s.startsWith("тумба под тв лофт 150")) return "ТВ Лофт 1500";
  if (s.startsWith("тумба под тв лофт")) return "ТВ Лофт";

  // Fallback: до первой точки (если есть), иначе полное название
  const dot = String(itemName).indexOf(".");
  return dot > 0 ? String(itemName).substring(0, dot).trim() : String(itemName).trim();
}

function setupLaborSheet() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  let sh = ss.getSheetByName(SHEETS.LABOR);
  if (!sh) sh = ss.insertSheet(SHEETS.LABOR);
  sh.clear();

  const headers = [[
    "Группа изделия", "Заказов", "Кол-во (шт)",
    "Пилка (мин)", "Кромка (мин)", "Присадка (мин)", "Итого (мин)",
    "Трудоемкость (ч/заказ)", "Трудоемкость (мин/шт)", "Трудоемкость (ч/шт)",
    "Доля пилки", "Доля кромки", "Доля присадки", "Последнее обновление"
  ]];
  sh.getRange(1, 1, 1, headers[0].length).setValues(headers);
  sh.getRange(1, 1, 1, headers[0].length).setFontWeight("bold").setBackground("#e0e0e0");
  sh.setFrozenRows(1);
  sh.setColumnWidth(1, 320);
  sh.getRange("B:G").setNumberFormat("0");
  sh.getRange("H:J").setNumberFormat("0.00");
