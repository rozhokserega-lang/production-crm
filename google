function calculateSheetsFromSelection() {
  const sheet = SpreadsheetApp.getActiveSpreadsheet().getActiveSheet();
  const rangeList = sheet.getActiveRangeList();
  const selections = rangeList ? rangeList.getRanges() : [];
  const ui = SpreadsheetApp.getUi();
  if (selections.length !== 2) {
    ui.alert(
      "Внимание",
      "Пожалуйста, выделите ДВА диапазона:\n\n1. Диапазон с размерами полок\n2. Диапазон с количествами\n\nУдерживайте Ctrl (Cmd на Mac) для второго диапазона",
      ui.ButtonSet.OK
    );
    return 0;
  }

  const sizesData = selections[0].getValues();
  const quantitiesData = selections[1].getValues();
  if (sizesData.length !== quantitiesData.length) {
    ui.alert("Ошибка", `Количество строк не совпадает:\nРазмеры: ${sizesData.length}\nКоличества: ${quantitiesData.length}`, ui.ButtonSet.OK);
    return 0;
  }

  const SHEET_WIDTH = 2800;
  const SHEET_HEIGHT = 2070;
  const EFFICIENCY = 0.85;
  const sheetArea = SHEET_WIDTH * SHEET_HEIGHT;
  const effectiveSheetArea = sheetArea * EFFICIENCY;
  let usedArea = 0;
  const shelves = [];

  for (let r = 0; r < sizesData.length; r++) {
    const name = String(sizesData[r][0] || "");
    const match = name.match(/(\d+)_(\d+)/);
    if (!match) continue;
    const width = parseInt(match[1], 10);
    const height = parseInt(match[2], 10);
    if (!width || !height) continue;

    let totalShelves = 0;
    for (let c = 0; c < quantitiesData[r].length; c++) {
      const value = quantitiesData[r][c];
      if (typeof value === "number" && !isNaN(value)) {
        totalShelves += value;
      } else if (typeof value === "string" && value.trim()) {
        const parsed = parseFloat(value.replace(",", "."));
        if (!isNaN(parsed)) totalShelves += parsed;
      }
    }
    if (totalShelves <= 0) continue;

    usedArea += width * height * totalShelves;
    shelves.push({ width, height, count: totalShelves });
  }

  if (!shelves.length) {
    ui.alert("Ошибка", "Не найдено данных для расчёта. Проверьте выделение.", ui.ButtonSet.OK);
    return 0;
  }

  const totalSheets = Math.ceil(usedArea / effectiveSheetArea);
  let result = "РАСЧЁТ РАСКРОЯ ЛИСТОВ 2800×2070 мм\n\nПолки для изготовления:\n";
  shelves.forEach(s => {
    result += `• ${s.width}×${s.height} мм - ${s.count} шт.\n`;
  });
  result += `\nОбщая площадь полок: ${(usedArea / 1000000).toFixed(2)} м²`;
  result += `\nПолезная площадь листа: ${(effectiveSheetArea / 1000000).toFixed(2)} м²`;
  result += `\n\n✅ Нужно листов: ${totalSheets}`;
  ui.alert("Результат расчёта", result, ui.ButtonSet.OK);
  return totalSheets;
}

function calculateExact() {
  const sheet = SpreadsheetApp.getActiveSheet();
  const ui = SpreadsheetApp.getUi();
  const SHEET_WIDTH = 2800;
  const SHEET_HEIGHT = 2070;

  const items = [
    { name: "ТВ тумба", detailsRows: [5, 6, 7], resultRowAbove: 7 },
    { name: "Донини", detailsRows: [10, 11, 12, 13], resultRowAbove: 13 },
    { name: "Донини Гранде", detailsRows: [16, 17, 18, 19, 20, 21], resultRowAbove: 21 },
    { name: "Авела Лайт", detailsRows: [24, 25, 26], resultRowAbove: 26 },
    { name: "Донини R", detailsRows: [42, 43, 44, 45, 46, 47], resultRowAbove: 47 },
  ];

  let totalAllSheets = 0;
  let resultMessage = "📊 РАСЧЕТ ПО ИЗДЕЛИЯМ\n─────────────────────\n";

  items.forEach(item => {
    let itemSheets = 0;
    let itemText = `\n🔹 ${item.name}\n`;

    item.detailsRows.forEach(rowNum => {
      const color = String(sheet.getRange(rowNum, 5).getValue() || "").toLowerCase().trim();
      const detailName = String(sheet.getRange(rowNum, 6).getValue() || "").toLowerCase();
      if (!color.includes("черный") || !detailName.includes("обвязка")) return;

      const sizeMatch = detailName.match(/\((\d+)_(\d+)\)/);
      if (!sizeMatch) return;
      const length = parseInt(sizeMatch[1], 10);
      const width = parseInt(sizeMatch[2], 10);
      const quantity = Number(sheet.getRange(rowNum, 7).getValue()) || 0;
      if (!(length > 0 && width > 0 && quantity > 0)) return;

      const stripsPerSheet = Math.floor(SHEET_HEIGHT / width);
      const perStrip = Math.floor(SHEET_WIDTH / length);
      const perSheet = stripsPerSheet * perStrip;
      if (perSheet <= 0) {
        itemText += `   • ${length}×${width}: ${quantity} шт → не помещается на лист\n`;
        return;
      }

      const sheetsNeeded = Math.ceil(quantity / perSheet);
      itemSheets += sheetsNeeded;
      itemText += `   • ${length}×${width}: ${quantity} шт → ${sheetsNeeded} листов (по ${perSheet} шт/лист)\n`;
    });

    if (itemSheets > 0) {
      sheet.getRange(item.resultRowAbove, 7).setValue(itemSheets);
      totalAllSheets += itemSheets;
      itemText += `   ✅ Итого: ${itemSheets} листов\n`;
      resultMessage += itemText;
    }
  });

  resultMessage += `\n─────────────────────\n✅ ВСЕГО ПО ВСЕМ ИЗДЕЛИЯМ: ${totalAllSheets} листов`;
  ui.alert("Результат расчета", resultMessage, ui.ButtonSet.OK);
}

function createProductionPlan() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const shipmentsSheet = ss.getSheetByName(SHEETS.SHIPMENT);
  const mebelSheet = ss.getSheetByName("Мебель");
  const planSheet = ss.getSheetByName("План");
  if (!shipmentsSheet || !mebelSheet || !planSheet) {
    SpreadsheetApp.getUi().alert('Листы "Отгрузки", "План" или "Мебель" не найдены!');
    return;
  }

  const range = shipmentsSheet.getRange(1, 1, shipmentsSheet.getLastRow(), shipmentsSheet.getLastColumn());
  const backgrounds = range.getBackgrounds();
  const values = range.getValues();
  const pinkCells = [];

  for (let i = 0; i < values.length; i++) {
    for (let j = 0; j < values[i].length; j++) {
      const bg = String(backgrounds[i][j] || "").toLowerCase();
      if (bg !== "#ff00ff" && !bg.includes("ff00ff")) continue;
      const value = parseFloat(values[i][j]);
      if (!(value > 0)) continue;
      pinkCells.push({
        row: i + 1,
        col: j + 1,
        quantity: value,
        fullName: String(values[i][5] || ""),
        planColumn: j + 1,
      });
    }
  }

  if (!pinkCells.length) {
    SpreadsheetApp.getUi().alert("❌ Нет выделенных ярко-розовых ячеек (#ff00ff)");
    return;
  }

  pinkCells.sort((a, b) => a.row - b.row);
  const selectedCell = pinkCells[0];
  const planNumber = shipmentsSheet.getRange(1, selectedCell.planColumn).getValue();
  const parsed = parseProductName_(selectedCell.fullName);

  planSheet.getRange(11, 6, 20, 2).clearContent();
  planSheet.getRange("B4").setValue(parsed.detailedName);
  planSheet.getRange("B6").setValue(parsed.colorName);
  planSheet.getRange("B11").setValue(parsed.firstName);
  planSheet.getRange("D11").setValue(selectedCell.quantity);
  planSheet.getRange("I7").setValue(planNumber);

  copyDetailsFromMebel_(mebelSheet, planSheet, parsed.productType, parsed.series);
  shipmentsSheet.getRange(selectedCell.row, selectedCell.col).setBackground("#ffff00");
  sendShipmentCellToWork_(shipmentsSheet, selectedCell.row, selectedCell.col);

  SpreadsheetApp.getUi().alert(`✅ План обновлен!\nНомер плана: ${planNumber}\nТип: ${parsed.productType}\nСерия: ${parsed.series || "-"}`);
}

function fillPlanFromShipmentCell_(shipmentsSheet, row, col, qtyOverride) {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const mebelSheet = ss.getSheetByName("Мебель");
  const planSheet = ss.getSheetByName("План");
  if (!mebelSheet || !planSheet) throw new Error('Листы "План" или "Мебель" не найдены');

  const fullName = String(shipmentsSheet.getRange(row, 6).getValue() || "");
  const qty = Number(qtyOverride != null ? qtyOverride : shipmentsSheet.getRange(row, col).getValue() || 0);
  const planNumber = shipmentsSheet.getRange(1, col).getValue();
  const parsed = parseProductName_(fullName);

  planSheet.getRange(11, 6, 20, 2).clearContent();
  planSheet.getRange("B4").setValue(parsed.detailedName);
  planSheet.getRange("B6").setValue(parsed.colorName);
  planSheet.getRange("B11").setValue(parsed.firstName);
  planSheet.getRange("D11").setValue(qty);
  planSheet.getRange("I7").setValue(planNumber);
  copyDetailsFromMebel_(mebelSheet, planSheet, parsed.productType, parsed.series);

  return { planNumber, productType: parsed.productType, series: parsed.series || "" };
}

function readPlanPreview_() {
