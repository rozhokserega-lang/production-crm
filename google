// ==================== STATS ====================
function calculateWorkMinutes(startDate, endDate) {
  if (!startDate || !endDate) return 0;
  const start = new Date(startDate), end = new Date(endDate);
  if (start >= end) return 0;

  function overlapMinutes_(aStart, aEnd, bStart, bEnd) {
    const s = Math.max(aStart.getTime(), bStart.getTime());
    const e = Math.min(aEnd.getTime(), bEnd.getTime());
    if (e <= s) return 0;
    return (e - s) / 60000;
  }

  let total = 0, current = new Date(start);
  while (current < end) {
    if (current.getDay() !== 0) {
      const ws = new Date(current); ws.setHours(8, 0, 0, 0);
      const we = new Date(current); we.setHours(18, 0, 0, 0);
      const ds = current < ws ? ws : current;
      const de = end < we ? end : we;
      if (ds < de) {
        let worked = (de - ds) / 60000;
        const ls = new Date(current); ls.setHours(12, 0, 0, 0);
        const le = new Date(current); le.setHours(13, 0, 0, 0);
        worked -= overlapMinutes_(ds, de, ls, le);
        if (worked > 0) total += worked;
      }
    }
    current.setDate(current.getDate() + 1);
    current.setHours(0, 0, 0, 0);
  }
  const rounded = Math.round(total);
  return (rounded === 0 && (end - start) > 0) ? 1 : rounded;
}

/**
 * Закрывает открытую паузу: добавляет бизнес-минуты (как в calculateWorkMinutes)
 * к накоплению и очищает ячейку «пауза с».
 */
function accumulatePauseAndClear_(sheet, row, pauseAtCol, pauseAccCol, time) {
  const pCell = sheet.getRange(row, pauseAtCol);
  const pa = pCell.getValue();
  if (!pa) return;
  const delta = calculateWorkMinutes(new Date(pa), time);
  const accCell = sheet.getRange(row, pauseAccCol);
  accCell.setValue((Number(accCell.getValue()) || 0) + delta);
  pCell.setValue("");
}

// ==================== MATERIALS BOOK (РАСХОД / ПРИХОД) ====================
function ruMonthName_(date) {
  const m = Number(Utilities.formatDate(new Date(date), "GMT+3", "M"));
  const map = {
    1: "январь", 2: "февраль", 3: "март", 4: "апрель", 5: "май", 6: "июнь",
    7: "июль", 8: "август", 9: "сентябрь", 10: "октябрь", 11: "ноябрь", 12: "декабрь"
  };
  return map[m] || "";
}

function findMonthlySheetByPrefix_(ss, prefix, date) {
  const month = ruMonthName_(date);
  const needle = (prefix + " " + month).toLowerCase();
  return ss.getSheets().find(sh => String(sh.getName() || "").toLowerCase().includes(needle)) || null;
}

function findTodayColumnInMonthlySheet_(sheet, date) {
  const lastCol = sheet.getLastColumn();
  if (lastCol < 3) return -1;

  const day = String(Number(Utilities.formatDate(new Date(date), "GMT+3", "d"))); // "6"
  const ddmm = Utilities.formatDate(new Date(date), "GMT+3", "dd.MM");
  const ddmmyyyy = Utilities.formatDate(new Date(date), "GMT+3", "dd.MM.yyyy");

  const row1 = sheet.getRange(1, 1, 1, lastCol).getDisplayValues()[0].map(v => String(v || "").trim());
  const row2 = sheet.getRange(2, 1, 1, lastCol).getDisplayValues()[0].map(v => String(v || "").trim());

  function match(v) {
    if (!v) return false;
    if (v === day) return true; // формат "1..31" как на вашем скрине
    if (v === ddmm || v.startsWith(ddmm) || v === ddmmyyyy || v.startsWith(ddmmyyyy)) return true;
    return false;
  }

  for (let c = 0; c < lastCol; c++) if (match(row1[c])) return c + 1;
  for (let c = 0; c < lastCol; c++) if (match(row2[c])) return c + 1;
  return -1;
}

function findOrCreateMaterialRowInSheet_(sheet, material) {
  const lastRow = Math.max(sheet.getLastRow(), 3);
  const mats = lastRow >= 4 ? sheet.getRange(4, 2, lastRow - 3, 1).getValues().flat() : [];
  const norm = String(material || "").trim().toLowerCase();
  for (let i = 0; i < mats.length; i++) {
    if (String(mats[i] || "").trim().toLowerCase() === norm) return i + 4;
  }
  const nr = sheet.getLastRow() + 1;
  sheet.getRange(nr, 2).setValue(material);
  return nr;
}

function postToMaterialsMonthlySheet_(prefix, material, qty, meta) {
  runWithScriptLock("materialsMonthlyPost", function () {
    const today = getMoscowTime();
    const book = getMaterialsBookSpreadsheet_();
    const monthly = findMonthlySheetByPrefix_(book, prefix, today);
    if (!monthly) throw new Error("Не найден лист '" + prefix + " " + ruMonthName_(today) + "'.");

    const dayCol = findTodayColumnInMonthlySheet_(monthly, today);
    if (dayCol === -1) throw new Error("Не найдена колонка сегодняшней даты (день месяца) в 1/2 строке.");

    const matRow = findOrCreateMaterialRowInSheet_(monthly, material);
    const cell = monthly.getRange(matRow, dayCol);
    const before = Number(cell.getValue()) || 0;
    cell.setValue(before + Number(qty || 0));

    // Комментарий по операции: ДОБАВЛЯЕМ новую запись, не перезаписываем старую заметку.
    const parts = [];
    if (meta && meta.orderId) parts.push("OrderID: " + meta.orderId);
    if (meta && meta.itemName) parts.push("Изделие: " + meta.itemName);
    if (meta && meta.week) parts.push("Неделя: " + meta.week);
    if (parts.length) {
      const stamp = Utilities.formatDate(today, "GMT+3", "dd.MM.yyyy HH:mm:ss");
      const entry = "[" + stamp + "] " + prefix + " " + Number(qty || 0) + "\n" + parts.join("\n");
      const prev = String(cell.getNote() || "").trim();
      const merged = prev ? (prev + "\n\n" + entry) : entry;
      // У заметок есть лимит, режем хвост если слишком длинно (чтобы не падать на записи).
      const MAX_NOTE = 45000;
      cell.setNote(merged.length > MAX_NOTE ? merged.slice(merged.length - MAX_NOTE) : merged);
    }

    try {
      logAction({
        source: (meta && meta.source) || "sheet",
        action: prefix === "расход" ? "MATERIAL_EXPENSE" : "MATERIAL_INCOME",
        orderId: (meta && meta.orderId) || "",
        row: (meta && meta.trackRow) || "",
        itemName: (meta && meta.itemName) || material,
        before: String(before),
        after: String(before + Number(qty || 0)),
        user: (meta && meta.user) || "",
        comment: prefix + " " + qty + " (" + material + ")"
      });
    } catch (_) {}
  });
}

function getSuggestedMaterialsFromCurrentExpenseSheet_() {
