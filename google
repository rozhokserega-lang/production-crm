function getMaterialMapSheet_() {
  // Основное имя вашего листа
  let sh = getSheet(SHEETS.MATERIAL_MAP);
  if (sh) return sh;

  // Совместимость со старым именем из прошлой версии
  sh = getSheet("Соответствие материалов");
  return sh;
}

function getMappedMaterialByItemName_(itemName) {
  const sh = getMaterialMapSheet_();
  if (!sh) return "";
  const last = sh.getLastRow();
  if (last < 2) return "";

  const rows = sh.getRange(2, 1, last - 1, 2).getValues();
  const target = normalizeMapKey_(itemName);
  if (!target) return "";

  // 1) Сначала точное совпадение по нормализованному названию
  for (let i = 0; i < rows.length; i++) {
    const key = normalizeMapKey_(rows[i][0]);
    const mat = String(rows[i][1] || "").trim();
    if (key && mat && key === target) return mat;
  }

  // 2) Fallback: включение строк (если в справочнике шаблон короче полного названия)
  for (let i = 0; i < rows.length; i++) {
    const key = normalizeMapKey_(rows[i][0]);
    const mat = String(rows[i][1] || "").trim();
    if (key && mat && target.includes(key)) return mat;
  }
  return "";
}

function getEffectiveMaterial_(itemName, rawMaterialCellValue) {
  const raw = String(rawMaterialCellValue == null ? "" : rawMaterialCellValue).trim();
  // Если в колонке C не текст (чекбокс true/false/пусто), берем из соответствия по названию изделия.
  if (!raw || raw === "true" || raw === "false") {
    return String(getMappedMaterialByItemName_(itemName) || "").trim();
  }
  return raw;
}

function getEffectiveMaterialFromRow_(trackSheet, row) {
  const item = trackSheet.getRange(row, COL.ITEM).getValue();
  const raw = trackSheet.getRange(row, COL.MATERIAL).getValue();
  return getEffectiveMaterial_(item, raw);
}

