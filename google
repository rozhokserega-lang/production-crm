function webApiDispatch_(action, payloadRaw) {
  try {
    if (!action) throw new Error("action не передан");
    let payload = {};
    try { payload = typeof payloadRaw === "string" ? JSON.parse(payloadRaw || "{}") : (payloadRaw || {}); } catch (_) { payload = {}; }

    let data;
    switch (action) {
      case "webGetOrdersAll": data = webGetOrdersAll(); break;
      case "webGetShipmentBoard": data = webGetShipmentBoard(); break;
      case "webGetOrdersPilka": data = webGetOrdersPilka(); break;
      case "webGetOrdersKromka": data = webGetOrdersKromka(); break;
      case "webGetOrdersPras": data = webGetOrdersPras(); break;
      case "webGetBackendRevision": data = webGetBackendRevision(); break;
      case "webSendShipmentToWork": data = webSendShipmentToWork(payload.row, payload.col); break;
      case "webPreviewPlanFromShipment": data = webPreviewPlanFromShipment(payload.row, payload.col); break;
      case "webPreviewPlansBatch": data = webPreviewPlansBatch(payload.items); break;
      case "webGetCurrentPlanPreview": data = webGetCurrentPlanPreview(); break;
      case "webSetPilkaInWork": data = webSetPilkaInWork(payload.orderId); break;
      case "webSetPilkaDone": data = webSetPilkaDone(payload.orderId); break;
      case "webSetKromkaInWork": data = webSetKromkaInWork(payload.orderId, payload.executor); break;
      case "webSetKromkaDone": data = webSetKromkaDone(payload.orderId); break;
      case "webSetPrasInWork": data = webSetPrasInWork(payload.orderId, payload.executor); break;
      case "webSetPrasDone": data = webSetPrasDone(payload.orderId); break;
      case "webSetPilkaPause": data = webSetPilkaPause(payload.orderId); break;
      case "webSetKromkaPause": data = webSetKromkaPause(payload.orderId); break;
      case "webSetPrasPause": data = webSetPrasPause(payload.orderId); break;
      case "webGetConsumeOptions": data = webGetConsumeOptions(payload.orderId); break;
      case "webConsumeSheetsByOrderId": data = webConsumeSheetsByOrderId(payload.orderId, payload.material, payload.qty); break;
      default:
        throw new Error("Неизвестный action: " + action);
    }
    if (/^webSet/.test(action) || action === "webConsumeSheetsByOrderId") {
      bumpBackendRevision_(action);
    }
    return ContentService
      .createTextOutput(JSON.stringify({ ok: true, data }))
      .setMimeType(ContentService.MimeType.JSON);
  } catch (err) {
    return ContentService
      .createTextOutput(JSON.stringify({ ok: false, error: String(err && err.message ? err.message : err) }))
      .setMimeType(ContentService.MimeType.JSON);
  }
}

