function withWebLock_(fn) {
  const lock = LockService.getScriptLock();
  let ok = false;
  // Несколько коротких попыток вместо одного длинного ожидания.
  for (let i = 0; i < 4; i++) {
    ok = lock.tryLock(1500);
    if (ok) break;
    Utilities.sleep(250);
  }
  if (!ok) throw new Error("Система занята другим действием. Повторите через 1-2 секунды.");
  try {
    return fn();
  } finally {
    lock.releaseLock();
  }
}

