function handleTelegramCallback(callback, track, allowedChatId, allowedUserIds) {
  const cbId = callback.id;
  const data = String(callback.data || "");
  const msg = callback.message || {};
  const chatId = String(msg.chat && msg.chat.id || "");
  const userId = String(callback.from && callback.from.id || "");

  const chatAllowed = chatId === allowedChatId;
  const userAllowed = !allowedUserIds || allowedUserIds.has(userId);
  if (!chatAllowed || !userAllowed) { answerCallback(cbId, "Нет доступа"); return; }

  if (data.startsWith("SBOR|")) {
    const orderId = data.split("|")[1];
    const res = markOrderAsAssembledById(track, orderId, { silentChatMessage: true, userId });
    if (!res.ok) { answerCallback(cbId, res.message || "Ошибка"); return; }

    const undoUntil = addMinutes(res.time, UNDO_MINUTES);
    track.getRange(res.row, COL.UNDO_UNTIL).setValue(undoUntil);

    const text =
      "✅ <b>СОБРАНО</b>\n\n" +
      "📦 Изделие: " + escapeHtml(res.itemName) + "\n" +
      "🎨 Материал: " + escapeHtml(res.material || "—") + "\n" +
      "📅 Неделя: " + escapeHtml(res.weekHeader) + "\n" +
      "🔢 Количество: " + Number(res.quantity || 0) + " шт\n" +
      "🔧 Присадка выполнена: " + escapeHtml(res.executor || "—") + "\n" +
      "🕐 Время: " + formatMoscowDate(res.time) + "\n\n" +
      "Можно отменить до: " + formatMoscowDate(undoUntil);

    editTelegramMessage(msg.chat.id, msg.message_id, text, {
      inline_keyboard: [[{ text: "↩️ ОТМЕНИТЬ СБОРКУ", callback_data: "UNSBOR|" + String(res.orderId) }]]
    });
    answerCallback(cbId, "Готово");
    return;
  }

  if (data.startsWith("UNSBOR|")) {
    const orderId = data.split("|")[1];
    const res = undoOrderAssemblyById(track, orderId, userId);
    if (!res.ok) { answerCallback(cbId, res.message || "Ошибка"); return; }

    editTelegramMessage(
      msg.chat.id, msg.message_id,
      "↩️ <b>СБОРКА ОТМЕНЕНА</b>\n\n📦 " + escapeHtml(res.itemName) + "\n🕐 " + formatMoscowDate(getMoscowTime())
    );
    clearTelegramButtons(msg.chat.id, msg.message_id);
    answerCallback(cbId, "Отменено");
    return;
  }

  answerCallback(cbId, "Неизвестная кнопка");
}

// ==================== TELEGRAM POLLING ====================
function processTelegramUpdates() {
  runWithScriptLock("processTelegramUpdates", function () {
    if (!isTelegramEnabled_()) return;
    const token = getTelegramToken();
    const allowedChatId = getTelegramChatId();
    const allowedUserIds = getAllowedUserIdsSet();

    const track = getSheet(SHEETS.TRACK);
    if (!track) return;

    let lastId = getTelegramLastUpdateId();
    let url = "https://api.telegram.org/bot" + token + "/getUpdates?timeout=5";
    if (lastId > 0) url += "&offset=" + (lastId + 1);

    const response = UrlFetchApp.fetch(url, { muteHttpExceptions: true });
    const code = response.getResponseCode();
    const body = response.getContentText();
    if (code < 200 || code >= 300) { console.error("getUpdates HTTP " + code + ": " + body); return; }

    let result;
    try { result = JSON.parse(body); } catch (e) { console.error("JSON parse error: " + e); return; }
    if (!result.ok) { console.error("Telegram API error: " + result.description); return; }

    const updates = result.result || [];
    if (!updates.length) return;

    for (const upd of updates) {
      const updateId = upd.update_id;

      if (upd.callback_query) {
        handleTelegramCallback(upd.callback_query, track, allowedChatId, allowedUserIds);
        setTelegramLastUpdateId(updateId);
        continue;
      }

      const msg = upd.message;
      if (!msg || !msg.text) { setTelegramLastUpdateId(updateId); continue; }

      const text = String(msg.text).trim();
      const chatId = String(msg.chat && msg.chat.id || "");
      const userId = String(msg.from && msg.from.id || "");
      const userName = (msg.chat && msg.chat.first_name) || (msg.from && msg.from.first_name) || "Пользователь";

      const chatAllowed = chatId === allowedChatId;
      const userAllowed = !allowedUserIds || allowedUserIds.has(userId);
      if (!chatAllowed || !userAllowed) { setTelegramLastUpdateId(updateId); continue; }

      if (text === "/start") {
        sendTelegramMessage(
          "🤖 Привет, " + escapeHtml(userName) + "!\n\n" +
          "Команды:\n/help\n/sbor [номер]\n/sborid [ID]\n/status [ID]\n\n" +
          "Лучше использовать кнопку ✅ СОБРАНО в уведомлении."
        );
      } else if (text === "/help") {
        sendTelegramMessage(
          "📋 Команды:\n" +
          "/sbor [номер] - legacy\n" +
          "/sborid [ID] - собрать по ID\n" +
          "/status [ID] - статус заказа\n" +
          "Кнопки: ✅ СОБРАНО / ↩️ ОТМЕНИТЬ"
        );
      } else if (/^\/status\s+[A-Z0-9-]+$/i.test(text)) {
        sendStatusByOrderId(track, text.split(/\s+/)[1].toUpperCase());
      } else if (/^\/sborid\s+[A-Z0-9-]+$/i.test(text)) {
        markOrderAsAssembledById(track, text.split(/\s+/)[1].toUpperCase(), { silentChatMessage: false, userId });
      } else if (/^\/sbor\s+\d+$/i.test(text)) {
        markOrderAsAssembledByRow(track, parseInt(text.split(/\s+/)[1], 10), { silentChatMessage: false, userId });
      }

      setTelegramLastUpdateId(updateId);
    }
  });
}

