const UNDO_MINUTES = 15;
/** Статус «на паузе» в выпадающих списках этапов */
const STATUS_PAUSE = "⏸ Пауза";

function getShipmentMaterialFromSheetRow_(sheet, row) {
  // В текущей таблице материал хранится в колонке A.
  // Оставляем fallback на G для совместимости со старыми данными.
  const fromA = String(sheet.getRange(row, 1).getValue() || "").trim();
  if (fromA) return fromA;
  return String(sheet.getRange(row, 7).getValue() || "").trim();
}

function sendShipmentCellToWork_(shipmentsSheet, row, col) {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const track = ss.getSheetByName(SHEETS.TRACK); // или 'Отследить заказ'
  if (!track) return;

  const item = shipmentsSheet.getRange(row, 6).getValue();      // F
  const material = getShipmentMaterialFromSheetRow_(shipmentsSheet, row);
  const qty = shipmentsSheet.getRange(row, col).getValue();
  const week = shipmentsSheet.getRange(1, col).getValue();

  if (!item || !qty || isNaN(Number(qty)) || Number(qty) <= 0) return;

  const existsRow = findOrderRowByKey(track, item, material, week);
  if (existsRow !== -1) return;

  const now = getMoscowTime();
  const orderId = generateOrderId();

  const newOrder = [
    now, item, false, week, Number(qty),
    "", "", "⏳ Ожидает",
    "", "", "", "⏳ Ожидает",
    "", "", "", "⏳ Ожидает",
    "⏳ Ожидает", "", "", "🟡 Новый заказ",
    orderId, "", "", false,
    "", "", "", "", "", ""
  ];

  const orderRow = track.getLastRow() + 1;
  track.getRange(orderRow, 1, 1, newOrder.length).setValues([newOrder]);
  setupStatusDropdowns(track, orderRow);
  track.getRange(orderRow, COL.CONSUME_SHEETS).insertCheckboxes();
  track.getRange(orderRow, COL.CONSUME_SHEETS).setValue(false);
  track.getRange(orderRow, COL.SHIPPED).insertCheckboxes();
  track.getRange(orderRow, COL.SHIPPED).setValue(false);
}
// ==================== BASIC HELPERS ====================
function getScriptProp(name, required = true) {
  const v = PropertiesService.getScriptProperties().getProperty(name);
  if (required && (!v || !String(v).trim())) throw new Error("Не задан Script Property: " + name);
  return v;
}
function setScriptProp(name, value) {
  PropertiesService.getScriptProperties().setProperty(name, String(value));
}
function getTelegramToken() { return String(getScriptProp(PROP.TELEGRAM_TOKEN, false) || "").trim(); }
function getTelegramChatId() { return String(getScriptProp(PROP.TELEGRAM_CHAT_ID, false) || "").trim(); }
function isTelegramEnabled_() { return !!(getTelegramToken() && getTelegramChatId()); }
function getAllowedUserIdsSet() {
  const raw = getScriptProp(PROP.TELEGRAM_ALLOWED_USER_IDS, false);
  if (!raw) return null;
  return new Set(raw.split(",").map(s => s.trim()).filter(Boolean));
}
function getTelegramLastUpdateId() {
  const savedId = getScriptProp(PROP.TELEGRAM_LAST_UPDATE_ID, false);
  return savedId ? parseInt(savedId, 10) : 0;
}
function setTelegramLastUpdateId(id) { setScriptProp(PROP.TELEGRAM_LAST_UPDATE_ID, id); }
function getSheet(name) { return SpreadsheetApp.getActiveSpreadsheet().getSheetByName(name); }
function getMaterialsBookSpreadsheet_() {
  const id = getScriptProp(PROP.MATERIALS_BOOK_SPREADSHEET_ID, false);
  return id ? SpreadsheetApp.openById(String(id).trim()) : SpreadsheetApp.getActiveSpreadsheet();
}
function escapeHtml(text) {
  return String(text == null ? "" : text).replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;");
}
function getMoscowTime() {
  const now = new Date();
  const str = Utilities.formatDate(now, "Europe/Moscow", "yyyy-MM-dd HH:mm:ss");
  return Utilities.parseDate(str, "Europe/Moscow", "yyyy-MM-dd HH:mm:ss");
}
function formatMoscowDate(dt) { return Utilities.formatDate(new Date(dt), "GMT+3", "dd.MM.yyyy HH:mm:ss"); }
function addMinutes(date, mins) { return new Date(new Date(date).getTime() + mins * 60000); }
function runWithScriptLock(name, fn) {
  const lock = LockService.getScriptLock();
  if (!lock.tryLock(5000)) { console.log(name + ": lock не получен, пропуск."); return; }
  try { fn(); } finally { lock.releaseLock(); }
}
function generateOrderId() { return Utilities.getUuid().slice(0, 8).toUpperCase(); }

// ==================== TELEGRAM API ====================
function tgPost(method, payload) {
  if (!isTelegramEnabled_()) return { ok: false, skipped: true, reason: "telegram_disabled" };
  const url = "https://api.telegram.org/bot" + getTelegramToken() + "/" + method;
  const response = UrlFetchApp.fetch(url, {
    method: "post",
    contentType: "application/json",
    payload: JSON.stringify(payload || {}),
    muteHttpExceptions: true,
  });
  const code = response.getResponseCode();
  const body = response.getContentText();

  let data = null;
  try { data = JSON.parse(body); } catch (_) {}

  if (code < 200 || code >= 300) console.error("Telegram HTTP " + code + " [" + method + "]: " + body);
  else if (data && data.ok === false) console.error("Telegram API error [" + method + "]: " + body);

  return data || { ok: false };
}

function sendTelegramMessage(message) {
  return tgPost("sendMessage", {
    chat_id: getTelegramChatId(),
    text: String(message),
    parse_mode: "HTML",
    disable_web_page_preview: true,
  });
}
function answerCallback(callbackQueryId, text) {
  tgPost("answerCallbackQuery", {
    callback_query_id: callbackQueryId,
    text: String(text || "ОК"),
    show_alert: false,
  });
}
function editTelegramMessage(chatId, messageId, text, replyMarkup) {
  const payload = { chat_id: chatId, message_id: messageId, text: String(text), parse_mode: "HTML" };
  if (replyMarkup) payload.reply_markup = replyMarkup;
  tgPost("editMessageText", payload);
}
function clearTelegramButtons(chatId, messageId) {
  tgPost("editMessageReplyMarkup", {
    chat_id: chatId,
    message_id: messageId,
    reply_markup: { inline_keyboard: [] },
  });
}
function sendTelegramAssemblyCard(itemName, material, weekHeader, quantity, executor, orderId) {
  if (!isTelegramEnabled_()) return "";
  const text =
    "✅ <b>ЗАКАЗ ГОТОВ К СБОРКЕ!</b>\n\n" +
    "📦 Изделие: " + escapeHtml(itemName) + "\n" +
    "🎨 Материал: " + escapeHtml(material || "—") + "\n" +
    "📅 Неделя: " + escapeHtml(weekHeader) + "\n" +
    "🔢 Количество: " + Number(quantity || 0) + " шт\n" +
    "🔧 Присадка выполнена: " + escapeHtml(executor || "—") + "\n" +
    "⏰ Время: " + formatMoscowDate(getMoscowTime());

  const res = tgPost("sendMessage", {
    chat_id: getTelegramChatId(),
    text,
    parse_mode: "HTML",
    reply_markup: {
      inline_keyboard: [[{ text: "✅ СОБРАНО", callback_data: "SBOR|" + String(orderId) }]]
    }
  });

  if (res && res.ok && res.result) return Number(res.result.message_id || "");
  return "";
}

