  return `<!doctype html>
<html>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Производство CRM</title>
  <style>
    body { font-family: Arial, sans-serif; margin: 0; background: #f3f4f6; color: #111827; }
    .wrap { max-width: 980px; margin: 0 auto; padding: 12px; }
    .head { display: flex; gap: 8px; align-items: center; justify-content: space-between; margin-bottom: 10px; }
    h1 { font-size: 18px; margin: 0; }
    button { border: 0; background: #1f4e78; color: #fff; padding: 8px 10px; border-radius: 8px; cursor: pointer; }
    button[disabled] { opacity: .5; cursor: not-allowed; }
    .btn { transition: transform .08s ease, box-shadow .15s ease, opacity .2s ease; box-shadow: 0 1px 2px rgba(0,0,0,.12); }
    .btn:active { transform: translateY(1px); }
    .btn-primary { background: #1f4e78; }
    .btn-success { background: #0f9d58; }
    .btn-active { box-shadow: 0 0 0 2px rgba(31,78,120,.25) inset; }
    .btn-busy { opacity: .6; cursor: wait; }
    .tabs { display: flex; gap: 8px; margin-bottom: 10px; flex-wrap: wrap; }
    .tab { background: #e5e7eb; color: #111827; }
    .tab.active { background: #1f4e78; color: #fff; }
    .card { background: #fff; border-radius: 10px; padding: 10px; margin-bottom: 8px; box-shadow: 0 1px 2px rgba(0,0,0,.08); }
    .row { display: flex; justify-content: space-between; gap: 8px; align-items: center; flex-wrap: wrap; }
    .actions { display: flex; gap: 6px; flex-wrap: wrap; align-items: center; }
    select, input { padding: 8px; border-radius: 8px; border: 1px solid #d1d5db; }
    .muted { color: #6b7280; font-size: 12px; }
    .metaStrong { color:#374151; font-size:14px; font-weight:700; letter-spacing:0; }
    .empty { text-align: center; color: #6b7280; padding: 28px 8px; }
    #consumeModal { position: fixed; inset: 0; background: rgba(0,0,0,.35); display:none; align-items:center; justify-content:center; }
    #consumeBox { background:#fff; border-radius:10px; padding:12px; width:min(520px,92vw); }
  </style>
</head>
<body>
  <div class="wrap">
    <div class="head">
      <h1 id="title">Пила</h1>
      <div style="display:flex;align-items:center;gap:10px;">
        <span id="lastSync" class="muted">Обновлено: —</span>
        <button onclick="load()">Обновить</button>
      </div>
    </div>
    <div class="tabs">
      <button id="tab_all" class="tab" onclick="switchTab('all')">Все заказы</button>
      <button id="tab_pilka" class="tab active" onclick="switchTab('pilka')">Пила</button>
      <button id="tab_kromka" class="tab" onclick="switchTab('kromka')">Кромка</button>
      <button id="tab_pras" class="tab" onclick="switchTab('pras')">Присадка</button>
    </div>
    <div style="margin-bottom:10px;">
      <input id="q" oninput="render(window._rows || [])" placeholder="Поиск: ID или изделие..." style="width:100%;max-width:420px;" />
    </div>
    <div id="list"></div>
  </div>

  <div id="consumeModal">
    <div id="consumeBox">
      <div style="font-weight:700;margin-bottom:8px;">Списание листов после пилки</div>
      <div id="consumeInfo" class="muted" style="margin-bottom:8px;"></div>
      <div style="margin-bottom:8px;">
        <label>Материал</label><br/>
        <input id="consumeMaterial" list="consumeMaterials" style="width:100%;" />
        <datalist id="consumeMaterials"></datalist>
      </div>
      <div style="margin-bottom:8px;">
        <label>Листов</label><br/>
        <input id="consumeQty" placeholder="например 1 или 2.5" style="width:100%;" />
      </div>
      <div id="consumeErr" style="color:#b91c1c;min-height:18px;"></div>
      <div class="actions">
        <button onclick="submitConsume()">✅ Списать</button>
        <button onclick="closeConsume()">Отмена</button>
      </div>
    </div>
  </div>

  <script>
    let activeTab = "pilka";
    let pendingConsume = null;
    const ACTION_REFRESH_DELAY_MS = 10000;
    const BACKEND_POLL_MS = 4000;
    let delayedRefreshTimer = null;
    let backendRevision = 0;
    let backendPollTimer = null;
    const TAB_TITLE = { all: "Все заказы", pilka: "Пила", kromka: "Кромка", pras: "Присадка" };
    function escapeHtml(v) {
      return String(v ?? "").replace(/[&<>"]/g, s => ({ "&":"&amp;","<":"&lt;",">":"&gt;",'"':"&quot;" }[s]));
    }
    function switchTab(tab) {
      activeTab = tab;
      document.getElementById("title").textContent = TAB_TITLE[tab] || "Пила";
      ["all", "pilka", "kromka", "pras"].forEach(t => {
        document.getElementById("tab_" + t).classList.toggle("active", t === tab);
      });
      load();
    }
    function load() {
      const list = document.getElementById("list");
      list.innerHTML = '<div class="empty">Загрузка...</div>';
      const rpc = activeTab === "all" ? "webGetOrdersAll" : activeTab === "kromka" ? "webGetOrdersKromka" : activeTab === "pras" ? "webGetOrdersPras" : "webGetOrdersPilka";
      google.script.run.withSuccessHandler(rows => {
        window._rows = rows || [];
        render(window._rows);
        const stamp = document.getElementById("lastSync");
        if (stamp) stamp.textContent = "Обновлено: " + new Date().toLocaleTimeString();
      }).withFailureHandler(err => {
        list.innerHTML = '<div class="empty">Ошибка: ' + escapeHtml(err && err.message || err) + '</div>';
      })[rpc]();
    }
    function scheduleDelayedLoad() {
      if (delayedRefreshTimer) clearTimeout(delayedRefreshTimer);
      delayedRefreshTimer = setTimeout(() => load(), ACTION_REFRESH_DELAY_MS);
    }
    function pollBackendRevision() {
      google.script.run.withSuccessHandler((payload) => {
        const rev = Number(payload && payload.revision || 0);
        if (!rev) return;
        if (!backendRevision) {
          backendRevision = rev;
          return;
        }
        if (rev > backendRevision) {
          backendRevision = rev;
          load();
        }
      }).withFailureHandler(() => {})["webGetBackendRevision"]();
    }
    function setupBackendPolling() {
      if (backendPollTimer) clearInterval(backendPollTimer);
      backendPollTimer = setInterval(() => pollBackendRevision(), BACKEND_POLL_MS);
      pollBackendRevision();
    }
    function btn(orderId, label, fn, disabled, tone, active) {
      const cls = 'btn ' + (tone || 'btn-primary') + (active ? ' btn-active' : '');
      const click = disabled ? '' : 'this.disabled=true;this.classList.add("btn-busy");' + fn + '(\\'' + encodeURIComponent(orderId) + '\\')';
      return '<button class="' + cls + '" ' + (disabled ? 'disabled ' : '') + 'onclick="' + click + '">' + label + '</button>';
    }
    function render(rows) {
      const list = document.getElementById("list");
      const q = String((document.getElementById("q") && document.getElementById("q").value) || "").toLowerCase().trim();
      const filtered = (rows || []).filter(r => !q || String(r.item || "").toLowerCase().includes(q) || String(r.orderId || "").toLowerCase().includes(q));
      if (!filtered.length) { list.innerHTML = '<div class="empty">Нет записей</div>'; return; }
      list.innerHTML = filtered.map(r => {
        const orderId = r.orderId || "";
        const pilkaDone = String(r.pilkaStatus || "").includes("Готово");
        const kromkaDone = String(r.kromkaStatus || "").includes("Готово");
        const prasDone = String(r.prasStatus || "").includes("Готово");
        const pilkaInProgress = String(r.pilkaStatus || "").includes("В работе");
        const kromkaInProgress = String(r.kromkaStatus || "").includes("В работе");
        const prasInProgress = String(r.prasStatus || "").includes("В работе");
        const exSel = activeTab === "kromka"
          ? '<select id="ex_' + escapeHtml(orderId) + '"><option>Слава</option><option>Сережа</option></select>'
          : activeTab === "pras"
            ? '<select id="ex_' + escapeHtml(orderId) + '"><option>Лёха</option><option>Виталик</option></select>'
            : '';
        const stageButtons = activeTab === "pilka"
          ? btn(orderId, "В работе", "pilkaInWork", pilkaDone, "btn-primary", pilkaInProgress) + btn(orderId, "Готово", "pilkaDone", pilkaDone, "btn-success", pilkaDone)
          : activeTab === "kromka"
            ? exSel + btn(orderId, "В работе", "kromkaInWork", kromkaDone, "btn-primary", kromkaInProgress) + btn(orderId, "Готово", "kromkaDone", kromkaDone, "btn-success", kromkaDone)
            : activeTab === "pras"
              ? exSel + btn(orderId, "В работе", "prasInWork", prasDone, "btn-primary", prasInProgress) + btn(orderId, "Готово", "prasDone", prasDone, "btn-success", prasDone)
              : btn(orderId, "Пила: Готово", "pilkaDone", pilkaDone, "btn-success", pilkaDone) +
                btn(orderId, "Кромка: Готово", "kromkaDone", kromkaDone, "btn-success", kromkaDone) +
                btn(orderId, "Присадка: Готово", "prasDone", prasDone, "btn-success", prasDone);
        const planLabel = r.week ? ' <span class="metaStrong">План: ' + escapeHtml(r.week) + '</span>' : '';
        return '<div class="card">' +
          '<div class="row"><strong>' + escapeHtml(r.item) + '</strong>' + planLabel + '<div class="actions">' + stageButtons + '</div></div>' +
          '<div class="row"><div class="muted">ID: ' + escapeHtml(orderId) + '</div><div class="metaStrong">Кол-во: ' + escapeHtml(r.qty) + '</div></div>' +
          '<div class="muted">Пилка: ' + escapeHtml(r.pilkaStatus) + ' | Кромка: ' + escapeHtml(r.kromkaStatus) + ' | Присадка: ' + escapeHtml(r.prasStatus) + '</div>' +
          '</div>';
      }).join("");
    }
    function call(method, orderIdRaw, arg) {
      const orderId = decodeURIComponent(orderIdRaw);
      const runner = google.script.run.withSuccessHandler((res) => {
        if (method === "webSetPilkaDone" && res && res.needConsume) openConsume(orderId);
        else scheduleDelayedLoad();
      }).withFailureHandler(err => alert("Ошибка: " + (err && err.message || err)));
      arg == null ? runner[method](orderId) : runner[method](orderId, arg);
    }
    function pilkaDone(orderId) { call("webSetPilkaDone", orderId); }
    function pilkaInWork(orderId) { call("webSetPilkaInWork", orderId); }
    function kromkaDone(orderId) { call("webSetKromkaDone", orderId); }
    function prasDone(orderId) { call("webSetPrasDone", orderId); }
    function kromkaInWork(orderIdRaw) {
      const orderId = decodeURIComponent(orderIdRaw);
      const ex = (document.getElementById("ex_" + orderId) || {}).value || "Слава";
      call("webSetKromkaInWork", orderIdRaw, ex);
    }
    function prasInWork(orderIdRaw) {
      const orderId = decodeURIComponent(orderIdRaw);
      const ex = (document.getElementById("ex_" + orderId) || {}).value || "Лёха";
      call("webSetPrasInWork", orderIdRaw, ex);
    }
    function openConsume(orderId) {
      google.script.run.withSuccessHandler(payload => {
        pendingConsume = payload;
        document.getElementById("consumeInfo").textContent = (payload.item || "") + " | Неделя: " + (payload.week || "");
        document.getElementById("consumeMaterial").value = payload.suggestedMaterial || "";
        document.getElementById("consumeQty").value = "";
        document.getElementById("consumeErr").textContent = "";
        document.getElementById("consumeMaterials").innerHTML = (payload.materials || []).map(m => '<option value="' + escapeHtml(m) + '"></option>').join("");
        document.getElementById("consumeModal").style.display = "flex";
      }).withFailureHandler(err => {
        alert("Пилка завершена, но не удалось открыть списание: " + (err && err.message || err));
        load();
      }).webGetConsumeOptions(orderId);
    }
    function closeConsume() { pendingConsume = null; document.getElementById("consumeModal").style.display = "none"; load(); }
    function submitConsume() {
      const mat = (document.getElementById("consumeMaterial").value || "").trim();
      const raw = (document.getElementById("consumeQty").value || "").trim().replace(",", ".");
      const qty = Number(raw);
      if (!pendingConsume) return;
      if (!mat) { document.getElementById("consumeErr").textContent = "Укажите материал"; return; }
      if (!raw || !isFinite(qty) || qty <= 0) { document.getElementById("consumeErr").textContent = "Некорректное количество"; return; }
      google.script.run.withSuccessHandler(() => closeConsume()).withFailureHandler(err => {
        document.getElementById("consumeErr").textContent = String(err && err.message ? err.message : err);
      }).webConsumeSheetsByOrderId(pendingConsume.orderId, mat, qty);
    }
    setupBackendPolling();
    load();
  </script>
</body>
</html>`;
} 