function clearTelegramQueue() {
  if (!isTelegramEnabled_()) { SpreadsheetApp.getUi().alert("Telegram выключен: задайте TELEGRAM_TOKEN и TELEGRAM_CHAT_ID"); return; }
  const token = getTelegramToken();
  const res = UrlFetchApp.fetch("https://api.telegram.org/bot" + token + "/getUpdates", { muteHttpExceptions: true });
  const result = JSON.parse(res.getContentText());

  if (result.ok && result.result && result.result.length > 0) {
    const lastId = result.result[result.result.length - 1].update_id;
    UrlFetchApp.fetch("https://api.telegram.org/bot" + token + "/getUpdates?offset=" + (lastId + 1) + "&timeout=5", { muteHttpExceptions: true });
    setTelegramLastUpdateId(lastId);
    SpreadsheetApp.getUi().alert("✅ Очищено " + result.result.length + " сообщений");
  } else {
    SpreadsheetApp.getUi().alert("Нет старых сообщений");
  }
}
