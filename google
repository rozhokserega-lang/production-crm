function webPreviewPlansBatch(items) {
  return withWebLock_(function() {
    const shipment = getSheet(SHEETS.SHIPMENT);
    if (!shipment) throw new Error("Лист '" + SHEETS.SHIPMENT + "' не найден");

    const arr = Array.isArray(items) ? items : [];
    if (!arr.length) throw new Error("Не переданы позиции для предпросмотра");

    const plans = [];
    for (const x of arr) {
      const r = Number(x && x.row || 0);
      const c = Number(x && x.col || 0);
      if (!(r >= 3 && r <= shipment.getLastRow())) continue;
      if (!(c >= 18 && c <= shipment.getLastColumn())) continue;
      const qty = Number(shipment.getRange(r, c).getValue() || 0);
      if (!(qty > 0)) continue;

      fillPlanFromShipmentCell_(shipment, r, c, qty);
      const p = readPlanPreview_();
      plans.push({
        row: r,
        col: c,
        plan: p,
      });
    }
    return { plans };
  });
}

function webPreviewPlanFromShipment(row, col) {
  return withWebLock_(function() {
    const shipment = getSheet(SHEETS.SHIPMENT);
    if (!shipment) throw new Error("Лист '" + SHEETS.SHIPMENT + "' не найден");
    const r = Number(row || 0);
    const c = Number(col || 0);
    if (!(r >= 3 && r <= shipment.getLastRow())) throw new Error("Некорректная строка");
    if (!(c >= 18 && c <= shipment.getLastColumn())) throw new Error("Некорректная колонка");

    const qty = Number(shipment.getRange(r, c).getValue() || 0);
    if (!(qty > 0)) throw new Error("В ячейке нет количества");

    fillPlanFromShipmentCell_(shipment, r, c, qty);
    return readPlanPreview_();
  });
}

function parseProductName_(fullName) {
  if (!fullName) {
    return { firstName: "Изделие", detailedName: "Изделие", colorName: "Цвет", productType: "unknown", series: "" };
  }
  let str = String(fullName).trim().replace(/\.+$/, "");
  const strLower = str.toLowerCase();
  let productType = "unknown";
  let series = "";

  if (strLower.includes("тумба под тв лофт 150")) productType = "tv_stand_150";
  else if (strLower.includes("тумба под тв")) productType = "tv_stand";
  else if (strLower.includes("donini 806")) productType = "donini_806";
  else if (strLower.includes("donini 750")) productType = "donini_750";
  else if (strLower.includes("donini grande")) productType = "donini_grande";
  else if (strLower.includes("avella lite")) productType = "avella_lite";
  else if (strLower.includes("avella")) productType = "avella";
  else if (strLower.includes("cremona")) productType = "cremona";
  else if (strLower.includes("премьер")) productType = "premier";
  else if (strLower.includes("stabile")) productType = "stabile";
  else if (strLower.includes("donini r")) productType = "donini_r";
  else if (strLower.includes("siena")) productType = "siena";
  else if (strLower.includes("solito2")) productType = "solito2";
  else if (strLower.includes("классико") || strLower.includes("classico")) productType = "classico";
  else if (strLower.includes("solito")) {
    productType = "solito";
    if (strLower.includes("1350")) series = "1350";
    else if (strLower.includes("1150")) series = "1150";
  }

  const firstSeparator = str.search(/[.,]/);
  const firstName = firstSeparator > 0 ? str.substring(0, firstSeparator).trim() : (str.split(" ")[0] || "Изделие");
  const lastDotIndex = str.lastIndexOf(".");
  const detailedName = lastDotIndex > 0 ? str.substring(0, lastDotIndex).trim() : str;
  let colorName = lastDotIndex > 0 ? str.substring(lastDotIndex + 1).trim() : "Цвет";
  if (!colorName) {
    const words = detailedName.split(" ");
    colorName = words[words.length - 1] || "Цвет";
  }

  return { firstName, detailedName, colorName, productType, series };
}

function copyDetailsFromMebel_(mebelSheet, planSheet, productType, series) {
  let detailsRange;
  switch (productType) {
    case "tv_stand_150": detailsRange = { startRow: 86, endRow: 88 }; break;
    case "tv_stand": detailsRange = { startRow: 5, endRow: 7 }; break;
    case "donini_806":
    case "donini_750": detailsRange = { startRow: 9, endRow: 12 }; break;
    case "donini_grande": detailsRange = { startRow: 15, endRow: 20 }; break;
    case "avella_lite": detailsRange = { startRow: 23, endRow: 25 }; break;
    case "cremona": detailsRange = { startRow: 29, endRow: 33 }; break;
    case "premier": detailsRange = { startRow: 35, endRow: 36 }; break;
    case "stabile": detailsRange = { startRow: 38, endRow: 40 }; break;
    case "donini_r": detailsRange = { startRow: 42, endRow: 47 }; break;
    case "siena": detailsRange = { startRow: 50, endRow: 56 }; break;
    case "solito2": detailsRange = { startRow: 62, endRow: 62 }; break;
    case "avella": detailsRange = { startRow: 66, endRow: 76 }; break;
    case "classico": detailsRange = { startRow: 78, endRow: 78 }; break;
    case "solito":
      detailsRange = series === "1150" ? { startRow: 82, endRow: 82 } : { startRow: 58, endRow: 58 };
      break;
    default:
      detailsRange = { startRow: 15, endRow: 20 };
  }

  let targetRow = 11;
  for (let row = detailsRange.startRow; row <= detailsRange.endRow; row++) {
    const detailName = mebelSheet.getRange(row, 6).getValue();
    const detailFormula = mebelSheet.getRange(row, 7).getFormula();
    if (!detailName) continue;

    planSheet.getRange(targetRow, 6).setValue(detailName);
    if (detailFormula) {
      planSheet.getRange(targetRow, 7).setFormula(detailFormula.replace(/D\d+/g, "D11"));
    } else {
      const detailValue = mebelSheet.getRange(row, 7).getValue();
      planSheet.getRange(targetRow, 7).setValue(typeof detailValue === "number" ? detailValue : "");
    }
    targetRow++;
  }
}

const PLANK_CFG_ = {
  SOURCE_SHEET: "Мебель",
  TRACK_SHEET: SHEETS.TRACK,
  PRINT_SHEET: "Печать_планки",
  COL_NAME: 6, // F
  COL_QTY: 7,  // G
};

function sendSelectedPlanksToWork() {
  const lock = LockService.getScriptLock();
  lock.waitLock(30000);
  try {
    const ss = SpreadsheetApp.getActiveSpreadsheet();
    const src = ss.getSheetByName(PLANK_CFG_.SOURCE_SHEET);
    const track = ss.getSheetByName(PLANK_CFG_.TRACK_SHEET);

    if (!src) throw new Error("Лист '" + PLANK_CFG_.SOURCE_SHEET + "' не найден");
    if (!track) throw new Error("Лист '" + PLANK_CFG_.TRACK_SHEET + "' не найден");

    const activeRange = src.getActiveRange();
    if (!activeRange) {
      SpreadsheetApp.getUi().alert("Сначала выдели строки с планками на листе 'Мебель'.");
      return;
    }

    const startRow = activeRange.getRow();
    const numRows = activeRange.getNumRows();
    const rows = src.getRange(startRow, PLANK_CFG_.COL_NAME, numRows, 2).getValues(); // F:G

    const selected = rows
      .map((r, i) => ({
        row: startRow + i,
        name: String(r[0] || "").trim(),
        qty: Number(r[1] || 0),
      }))
      .filter(x => x.name && x.qty > 0);

    if (!selected.length) {
      SpreadsheetApp.getUi().alert(
        "В выделении нет валидных строк.\nПроверь, что в F есть наименование, а в G количество > 0."
      );
      return;
    }

    const now = getMoscowTime();
    const batchId = "OBV-" + Utilities.formatDate(now, Session.getScriptTimeZone(), "yyMMdd-HHmmss");
    const week = getIsoWeek_(now);

    buildPlanksPrintSheet_(ss, selected, batchId, now);
    const added = appendPlanksToTrack_(track, selected, batchId, week, now);

    SpreadsheetApp.getUi().alert(
      "Готово.\n" +
      "Пакет: " + batchId + "\n" +
      "Позиции выделено: " + selected.length + "\n" +
      "Добавлено в трек: " + added + "\n" +
      "Печать: '" + PLANK_CFG_.PRINT_SHEET + "'."
    );
  } finally {
    lock.releaseLock();
  }
}

function buildPlanksPrintSheet_(ss, selected, batchId, now) {
  let sh = ss.getSheetByName(PLANK_CFG_.PRINT_SHEET);
  if (!sh) sh = ss.insertSheet(PLANK_CFG_.PRINT_SHEET);
  sh.clear();

  const tz = Session.getScriptTimeZone();
  const dateStr = Utilities.formatDate(now, tz, "dd.MM.yyyy HH:mm");

  sh.getRange("A1").setValue("ЗАДАНИЕ В РАБОТУ: ПЛАНКИ ОБВЯЗКИ").setFontWeight("bold").setFontSize(14);
  sh.getRange("A2").setValue("Пакет: " + batchId);
  sh.getRange("A3").setValue("Дата: " + dateStr);

  sh.getRange(5, 1, 1, 4).setValues([["№", "Наименование", "Кол-во", "Отметка"]]);
  sh.getRange(5, 1, 1, 4).setFontWeight("bold").setBackground("#e5e7eb");

  const body = selected.map((x, idx) => [idx + 1, x.name, x.qty, ""]);
  sh.getRange(6, 1, body.length, 4).setValues(body);
  sh.getRange(6, 3, body.length, 1).setNumberFormat("0");

  sh.setColumnWidth(1, 50);
  sh.setColumnWidth(2, 420);
  sh.setColumnWidth(3, 100);
  sh.setColumnWidth(4, 220);
  sh.getRange(5, 1, body.length + 1, 4).setBorder(true, true, true, true, true, true);

  const signRow = 7 + body.length;
  sh.getRange("A" + signRow).setValue("Выдал в работу: __________________");
  sh.getRange("C" + signRow).setValue("Принял: __________________");
  sh.setFrozenRows(5);
}

function appendPlanksToTrack_(track, selected, batchId, week, now) {
  const toInsert = [];
  for (const x of selected) {
    const itemName = x.name + " [" + batchId + "]";
    const existsRow = findOrderRowByKey(track, itemName, null, week);
