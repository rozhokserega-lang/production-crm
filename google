function refreshLaborSheet() {
  const track = getSheet(SHEETS.TRACK);
  if (!track) return;

  let labor = getSheet(SHEETS.LABOR);
  if (!labor) {
    setupLaborSheet();
    labor = getSheet(SHEETS.LABOR);
    if (!labor) return;
  }

  const lastRow = track.getLastRow();
  labor.getRange("A2:N10000").clearContent();
  if (lastRow < 2) return;

  const data = track.getRange(2, 1, lastRow - 1, COL.LAST).getValues();
  const byGroup = {};

  data.forEach(r => {
    const item = String(r[COL.ITEM - 1] || "").trim();
    const group = getLaborGroupName_(item);
    if (!group) return;

    const qty = Number(r[COL.QTY - 1] || 0);
    const pS = r[COL.PILKA_START - 1], pE = r[COL.PILKA_END - 1];
    const kS = r[COL.KROMKA_START - 1], kE = r[COL.KROMKA_END - 1];
    const rS = r[COL.PRAS_START - 1], rE = r[COL.PRAS_END - 1];

    // Берем те же правила расчета, что и в статистике (с вычетом пауз).
    const pPause = Number(r[COL.PILKA_PAUSE_ACC - 1] || 0);
    const kPause = Number(r[COL.KROMKA_PAUSE_ACC - 1] || 0);
    const rPause = Number(r[COL.PRAS_PAUSE_ACC - 1] || 0);
    const pM = (pS && pE) ? Math.max(0, calculateWorkMinutes(pS, pE) - pPause) : 0;
    const kM = (kS && kE) ? Math.max(0, calculateWorkMinutes(kS, kE) - kPause) : 0;
    const rM = (rS && rE) ? Math.max(0, calculateWorkMinutes(rS, rE) - rPause) : 0;
    const total = pM + kM + rM;

    // В трудоемкость включаем только заказы с фактически зафиксированной работой.
    if (total <= 0) return;

    if (!byGroup[group]) byGroup[group] = { orders: 0, qty: 0, p: 0, k: 0, r: 0, t: 0 };
    byGroup[group].orders += 1;
    byGroup[group].qty += qty;
    byGroup[group].p += pM;
    byGroup[group].k += kM;
    byGroup[group].r += rM;
    byGroup[group].t += total;
  });

  const rows = Object.keys(byGroup).sort().map(group => {
    const x = byGroup[group];
    const hPerOrder = x.orders ? (x.t / 60 / x.orders) : 0;
    const minPerUnit = x.qty ? (x.t / x.qty) : 0;
    const hPerUnit = x.qty ? (x.t / 60 / x.qty) : 0;
    const pShare = x.t ? (x.p / x.t) : 0;
    const kShare = x.t ? (x.k / x.t) : 0;
    const rShare = x.t ? (x.r / x.t) : 0;
    return [group, x.orders, x.qty, x.p, x.k, x.r, x.t, hPerOrder, minPerUnit, hPerUnit, pShare, kShare, rShare, formatMoscowDate(getMoscowTime())];
  });

  if (rows.length) {
    labor.getRange(2, 1, rows.length, rows[0].length).setValues(rows);
  }
}

// ==================== CHECK NOTIFICATIONS ====================
function checkAndSendNotifications() {
  runWithScriptLock("checkAndSendNotifications", function () {
    const track = getSheet(SHEETS.TRACK);
    if (!track) return;
    const lastRow = track.getLastRow();
    if (lastRow < 2) return;

    const data = track.getRange(2, 1, lastRow - 1, COL.LAST).getValues();

    for (let i = 0; i < data.length; i++) {
      const row = i + 2;
      const r = data[i];

      const item = r[COL.ITEM - 1];
      const material = getEffectiveMaterial_(item, r[COL.MATERIAL - 1]);
      const week = r[COL.WEEK - 1];
      const qty = r[COL.QTY - 1];
      const exec = r[COL.PRAS_EXEC - 1];
      const notifSent = r[COL.NOTIF_SENT - 1];
      const overall = r[COL.OVERALL_STATUS - 1];
      let orderId = r[COL.ORDER_ID - 1];
      const tgMessageId = r[COL.TG_MESSAGE_ID - 1];

      if (overall === "📦 Ожидает сборки" && notifSent !== "SENT" && !tgMessageId) {
        if (!orderId) {
          orderId = generateOrderId();
          track.getRange(row, COL.ORDER_ID).setValue(orderId);
        }
