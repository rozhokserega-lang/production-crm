function webGetOrdersByTab_(tab) {
  const track = getSheet(SHEETS.TRACK);
  if (!track) return [];
  const lastRow = track.getLastRow();
  if (lastRow < 2) return [];

  const sheetsNeededMap = buildShipmentSheetsNeededMap_();
  const data = track.getRange(2, 1, lastRow - 1, COL.LAST).getValues();
  return data
    .map((r, i) => {
      const item = String(r[COL.ITEM - 1] || "").trim();
      const week = String(r[COL.WEEK - 1] || "").trim();
      const material = String(getEffectiveMaterial_(item, r[COL.MATERIAL - 1]) || "").trim();
      const key = [normalizeLookupKey_(item), normalizeLookupKey_(material), normalizeLookupKey_(week)].join("||");
      const fallbackKey = [normalizeLookupKey_(item), normalizeLookupKey_(week)].join("||");
      return {
        row: i + 2,
      createdAt: r[COL.CREATED_AT - 1] || "",
        orderId: String(r[COL.ORDER_ID - 1] || ""),
        item,
        week,
        qty: Number(r[COL.QTY - 1] || 0),
        sheetsNeeded: Number(sheetsNeededMap[key] || sheetsNeededMap[fallbackKey] || 0),
        pilkaStatus: String(r[COL.PILKA_STATUS - 1] || ""),
        kromkaStatus: String(r[COL.KROMKA_STATUS - 1] || ""),
        prasStatus: String(r[COL.PRAS_STATUS - 1] || ""),
        assemblyStatus: String(r[COL.ASSEMBLY_STATUS - 1] || ""),
        overall: String(r[COL.OVERALL_STATUS - 1] || ""),
      };
    })
    .filter(x => {
      const pilkaDone = statusIsDone_(x.pilkaStatus);
      const kromkaDone = statusIsDone_(x.kromkaStatus);
      const prasDone = statusIsDone_(x.prasStatus);
      const pilkaWork = statusIsInWork_(x.pilkaStatus);
      const kromkaWork = statusIsInWork_(x.kromkaStatus);
      const prasWork = statusIsInWork_(x.prasStatus);
      const hasPause = statusIsPause_(x.pilkaStatus) || statusIsPause_(x.kromkaStatus) || statusIsPause_(x.prasStatus);

      if (tab === "paused") {
        return hasPause;
      }
      if (tab === "ready") {
        return pilkaDone && kromkaDone && prasDone && !statusIsAssembled_(x.assemblyStatus);
      }
      if (tab === "all") return true;
      if (tab === "pilka") return !pilkaDone;
      if (tab === "kromka") return pilkaDone && !kromkaDone;
      if (tab === "pras") return pilkaDone && kromkaDone && !prasDone;
      return pilkaWork || kromkaWork || prasWork;
    });
}

function buildShipmentSheetsNeededMap_() {
  const shipment = getSheet(SHEETS.SHIPMENT);
  if (!shipment) return {};
  const lastRow = shipment.getLastRow();
  const lastCol = shipment.getLastColumn();
  if (lastRow < 3 || lastCol < 18) return {};

  const values = shipment.getRange(1, 1, lastRow, lastCol).getValues();
  const map = {};
  for (let r = 3; r <= lastRow; r++) {
    const item = String(values[r - 1][5] || "").trim(); // F
    if (!item) continue;
    const material = String(getShipmentMaterialFromSheetRow_(shipment, r) || values[r - 1][0] || values[r - 1][6] || "").trim(); // unified with work-send lookup
    const outputPerSheet = Number(values[r - 1][1] || 0); // B
    if (!(outputPerSheet > 0)) continue;
    for (let c = 18; c <= lastCol; c++) {
      const qty = Number(values[r - 1][c - 1] || 0);
      if (!(qty > 0)) continue;
      const week = String(values[0][c - 1] || "").trim();
      if (!week) continue;
      const sheets = Math.ceil(qty / outputPerSheet);
      const key = [normalizeLookupKey_(item), normalizeLookupKey_(material), normalizeLookupKey_(week)].join("||");
      const fallbackKey = [normalizeLookupKey_(item), normalizeLookupKey_(week)].join("||");
      map[key] = sheets;
      if (!map[fallbackKey] || sheets > map[fallbackKey]) {
        map[fallbackKey] = sheets;
      }
    }
  }
  return map;
}

function normalizeLookupKey_(v) {
  return String(v || "")
    .toLowerCase()
    .replace(/[ё]/g, "е")
    .replace(/[^\p{L}\p{N}\s]/gu, " ")
    .replace(/\s+/g, " ")
    .trim();
}

