function formatWorkTime(minutes) {
  const h = Math.floor(minutes / 60), m = minutes % 60;
  if (h === 0) return m + " мин";
  if (m === 0) return h + " ч";
  return h + " ч " + m + " мин";
}
function addToStatistics(track, row, refreshLabor) {
  const needRefreshLabor = (refreshLabor !== false);
  const stats = getSheet(SHEETS.STATS);
  if (!stats) return;

  const item = track.getRange(row, COL.ITEM).getValue();
  const material = getEffectiveMaterialFromRow_(track, row);
  const week = track.getRange(row, COL.WEEK).getValue();
  const qty = track.getRange(row, COL.QTY).getValue();

  const pS = track.getRange(row, COL.PILKA_START).getValue();
  const pE = track.getRange(row, COL.PILKA_END).getValue();
  const pPause = Number(track.getRange(row, COL.PILKA_PAUSE_ACC).getValue()) || 0;
  const pM = (pS && pE) ? Math.max(0, calculateWorkMinutes(pS, pE) - pPause) : 0;

  const kS = track.getRange(row, COL.KROMKA_START).getValue();
  const kE = track.getRange(row, COL.KROMKA_END).getValue();
  const kX = track.getRange(row, COL.KROMKA_EXEC).getValue();
  const kPause = Number(track.getRange(row, COL.KROMKA_PAUSE_ACC).getValue()) || 0;
  const kM = (kS && kE) ? Math.max(0, calculateWorkMinutes(kS, kE) - kPause) : 0;

  const rS = track.getRange(row, COL.PRAS_START).getValue();
  const rE = track.getRange(row, COL.PRAS_END).getValue();
  const rX = track.getRange(row, COL.PRAS_EXEC).getValue();
  const rPause = Number(track.getRange(row, COL.PRAS_PAUSE_ACC).getValue()) || 0;
  const rM = (rS && rE) ? Math.max(0, calculateWorkMinutes(rS, rE) - rPause) : 0;

  const total = pM + kM + rM;
  const completion = track.getRange(row, COL.ASSEMBLY_TIME).getValue() || rE || kE || pE;

  const payload = [[
    item, material, week, qty,
    pM, kM, kX || "",
    rM, rX || "",
    total, formatWorkTime(total), completion
  ]];

  const last = stats.getLastRow();
  if (last > 1) {
    const existing = stats.getRange(2, 1, last - 1, 12).getValues();
    const weekNorm = String(week || "").trim();
    for (let i = 0; i < existing.length; i++) {
      const existingWeek = String(existing[i][2] || "").trim();
      if (existing[i][0] === item && existing[i][1] === material && existingWeek === weekNorm) {
        const targetRow = i + 2;
        stats.getRange(targetRow, 1, 1, 12).setValues(payload);
        stats.getRange(targetRow, 5, 1, 5).setNumberFormat("0");
        if (needRefreshLabor) refreshLaborSheet();
        return;
      }
    }
  }

  const nr = stats.getLastRow() + 1;
  stats.getRange(nr, 1, 1, 12).setValues(payload);
  stats.getRange(nr, 5, 1, 5).setNumberFormat("0");
  if (needRefreshLabor) refreshLaborSheet();
}

function recalculateAllStatisticsFromTrack() {
  const track = getSheet(SHEETS.TRACK);
  const stats = getSheet(SHEETS.STATS);
  if (!track || !stats) {
    SpreadsheetApp.getUi().alert("❌ Не найден лист отслеживания или статистики.");
    return;
  }

  const lastTrackRow = track.getLastRow();
  if (lastTrackRow < 2) {
    if (stats.getLastRow() > 1) stats.getRange(2, 1, stats.getLastRow() - 1, 12).clearContent();
    SpreadsheetApp.getUi().alert("ℹ️ В отслеживании нет данных для пересчета.");
    return;
  }

  if (stats.getLastRow() > 1) stats.getRange(2, 1, stats.getLastRow() - 1, 12).clearContent();

  for (let row = 2; row <= lastTrackRow; row++) {
    const item = track.getRange(row, COL.ITEM).getValue();
    const week = track.getRange(row, COL.WEEK).getValue();
    if (!item && !week) continue;
    addToStatistics(track, row, false);
  }
  refreshLaborSheet();

  SpreadsheetApp.getUi().alert("✅ Статистика пересчитана с учетом обеда 12:00-13:00.");
}

