}
function logAction(obj) {
  const sh = ensureHistorySheet();
  sh.appendRow([
    formatMoscowDate(getMoscowTime()),
    obj.source || "",
    obj.action || "",
    obj.orderId || "",
    obj.row || "",
    obj.itemName || "",
    obj.before || "",
    obj.after || "",
    obj.user || "",
    obj.comment || ""
  ]);
}

// ==================== ORDER HELPERS ====================
function ensureOrderIdForRow(trackSheet, row) {
  let id = trackSheet.getRange(row, COL.ORDER_ID).getValue();
  if (!id) {
    id = generateOrderId();
    trackSheet.getRange(row, COL.ORDER_ID).setValue(id);
  }
  return String(id);
}
function ensureOrderIdsForAllRows() {
  const sh = getSheet(SHEETS.TRACK);
  if (!sh) return;
  const lastRow = sh.getLastRow();
  if (lastRow < 2) return;
  const ids = sh.getRange(2, COL.ORDER_ID, lastRow - 1, 1).getValues();
  let changed = false;
  for (let i = 0; i < ids.length; i++) {
    if (!ids[i][0]) { ids[i][0] = generateOrderId(); changed = true; }
  }
  if (changed) sh.getRange(2, COL.ORDER_ID, lastRow - 1, 1).setValues(ids);
  SpreadsheetApp.getUi().alert("✅ Order ID проверены и заполнены.");
}
function findOrderRowById(sheet, orderId) {
  const lastRow = sheet.getLastRow();
  if (lastRow < 2) return -1;
  const ids = sheet.getRange(2, COL.ORDER_ID, lastRow - 1, 1).getValues().flat();
  const idx = ids.findIndex(v => String(v).toUpperCase() === String(orderId).toUpperCase());
  return idx === -1 ? -1 : idx + 2;
}
function findOrderRowByKey(sheet, itemName, material, weekHeader) {
  const lastRow = sheet.getLastRow();
  if (lastRow < 1) return -1;
  const data = sheet.getRange(1, 1, lastRow, COL.LAST).getValues();
  for (let i = 0; i < data.length; i++) {
    const rowMaterial = getEffectiveMaterial_(data[i][COL.ITEM - 1], data[i][COL.MATERIAL - 1]);
    const materialMatches = material ? rowMaterial === material : true;
    if (data[i][COL.ITEM - 1] === itemName &&
        materialMatches &&
        data[i][COL.WEEK - 1] == weekHeader) return i + 1;
  }
  return -1;
}

// ==================== PIPELINE HANDLERS ====================
function handlePilkaStatus(sheet, row, status, time) {
  const s = sheet.getRange(row, COL.PILKA_START);
  const e = sheet.getRange(row, COL.PILKA_END);
  const pauseAt = sheet.getRange(row, COL.PILKA_PAUSE_AT);

  if (status === "🔨 В работе" && s.getValue() && !e.getValue()) {
    accumulatePauseAndClear_(sheet, row, COL.PILKA_PAUSE_AT, COL.PILKA_PAUSE_ACC, time);
  }
  if (status === "🔨 В работе" && !s.getValue()) s.setValue(time);

  if (status === STATUS_PAUSE && s.getValue() && !e.getValue() && !pauseAt.getValue()) {
    pauseAt.setValue(time);
  }

  if (status === "✅ Готово" && s.getValue() && !e.getValue()) {
    accumulatePauseAndClear_(sheet, row, COL.PILKA_PAUSE_AT, COL.PILKA_PAUSE_ACC, time);
    e.setValue(time);
    addToStatistics(sheet, row);
    // Автозапуск списания отключен: чекбокс C пользователь отмечает вручную.
  }
}
function handleKromkaStatus(sheet, row, status, time) {
  const s = sheet.getRange(row, COL.KROMKA_START);
  const e = sheet.getRange(row, COL.KROMKA_END);
  const ex = sheet.getRange(row, COL.KROMKA_EXEC);
  const pauseAt = sheet.getRange(row, COL.KROMKA_PAUSE_AT);

  if ((status === "🔪 В работе (Слава)" || status === "🔪 В работе (Сережа)") && s.getValue() && !e.getValue()) {
    accumulatePauseAndClear_(sheet, row, COL.KROMKA_PAUSE_AT, COL.KROMKA_PAUSE_ACC, time);
  }
  if (status === "🔪 В работе (Слава)" && !s.getValue()) { s.setValue(time); ex.setValue("Слава"); }
  if (status === "🔪 В работе (Сережа)" && !s.getValue()) { s.setValue(time); ex.setValue("Сережа"); }

  if (status === STATUS_PAUSE && s.getValue() && !e.getValue() && !pauseAt.getValue()) {
    pauseAt.setValue(time);
  }

  if (status === "✅ Готово" && s.getValue() && !e.getValue()) {
    accumulatePauseAndClear_(sheet, row, COL.KROMKA_PAUSE_AT, COL.KROMKA_PAUSE_ACC, time);
    e.setValue(time);
    addToStatistics(sheet, row);
  }
}
function handlePrasadkaStatus(sheet, row, status, time) {
  const s = sheet.getRange(row, COL.PRAS_START);
  const e = sheet.getRange(row, COL.PRAS_END);
  const ex = sheet.getRange(row, COL.PRAS_EXEC);
  const pauseAt = sheet.getRange(row, COL.PRAS_PAUSE_AT);

  if ((status === "🔧 В работе (Лёха)" || status === "🔧 В работе (Виталик)") && s.getValue() && !e.getValue()) {
    accumulatePauseAndClear_(sheet, row, COL.PRAS_PAUSE_AT, COL.PRAS_PAUSE_ACC, time);
  }
  if (status === "🔧 В работе (Лёха)" && !s.getValue()) { s.setValue(time); ex.setValue("Лёха"); }
  if (status === "🔧 В работе (Виталик)" && !s.getValue()) { s.setValue(time); ex.setValue("Виталик"); }

  if (status === STATUS_PAUSE && s.getValue() && !e.getValue() && !pauseAt.getValue()) {
    pauseAt.setValue(time);
  }

  if (status === "✅ Готово" && s.getValue() && !e.getValue()) {
    accumulatePauseAndClear_(sheet, row, COL.PRAS_PAUSE_AT, COL.PRAS_PAUSE_ACC, time);
    e.setValue(time);
    addToStatistics(sheet, row);
  }
}
function handleAssemblyStatus(sheet, row, status, time) {
  const t = sheet.getRange(row, COL.ASSEMBLY_TIME);
  if (status === "✅ СОБРАНО" && !t.getValue()) t.setValue(time);
}

// NEW: чекбокс "Отправлен"
function handleShippedCheckbox(trackSheet, row, shipped) {
  const shipmentSheet = getSheet(SHEETS.SHIPMENT);
  if (!shipmentSheet) return;

  const itemName = trackSheet.getRange(row, COL.ITEM).getValue();
  const material = getEffectiveMaterialFromRow_(trackSheet, row);
  const weekHeader = trackSheet.getRange(row, COL.WEEK).getValue();

  for (let r = 3; r <= shipmentSheet.getLastRow(); r++) {
    if (shipmentSheet.getRange(r, 6).getValue() === itemName &&
        getShipmentMaterialFromSheetRow_(shipmentSheet, r) === material) {
      for (let c = 18; c <= shipmentSheet.getLastColumn(); c++) {
        if (shipmentSheet.getRange(1, c).getValue() == weekHeader) {
          const cell = shipmentSheet.getRange(r, c);
          if (shipped === true) {
            cell.setBackground("#ff0000");
            cell.setNote("🚚 Отправлено: " + formatMoscowDate(getMoscowTime()));
            logAction({
              source: "sheet",
              action: "MARK_SHIPPED",
              orderId: String(trackSheet.getRange(row, COL.ORDER_ID).getValue() || ""),
              row,
              itemName,
              before: "not shipped",
              after: "shipped",
              user: "manual"
            });
          } else {
            updateShipmentColor(trackSheet, row);
            updateShipmentNote(trackSheet, row, trackSheet.getRange(row, COL.OVERALL_STATUS).getValue());
            logAction({
              source: "sheet",
              action: "UNMARK_SHIPPED",
              orderId: String(trackSheet.getRange(row, COL.ORDER_ID).getValue() || ""),
              row,
              itemName,
              before: "shipped",
              after: "not shipped",
              user: "manual"
            });
          }
          return;
        }
      }
    }
  }
}

function updateOverallStatus(sheet, row) {
  const pilka = sheet.getRange(row, COL.PILKA_STATUS).getValue();
  const kromka = sheet.getRange(row, COL.KROMKA_STATUS).getValue();
  const pras = sheet.getRange(row, COL.PRAS_STATUS).getValue();
  const assembly = sheet.getRange(row, COL.ASSEMBLY_STATUS).getValue();

  const notifSentCell = sheet.getRange(row, COL.NOTIF_SENT);
  const overallCell = sheet.getRange(row, COL.OVERALL_STATUS);

  let status = "";
  if (assembly === "✅ СОБРАНО") status = "✅ СОБРАНО!";
  else if (pilka === "✅ Готово" && kromka === "✅ Готово" && pras === "✅ Готово") {
    status = "📦 Ожидает сборки";

    const notifSent = notifSentCell.getValue();
    const tgMsgId = sheet.getRange(row, COL.TG_MESSAGE_ID).getValue();
    if (notifSent !== "SENT" && !tgMsgId) {
      const item = sheet.getRange(row, COL.ITEM).getValue();
      const mat = getEffectiveMaterialFromRow_(sheet, row);
      const week = sheet.getRange(row, COL.WEEK).getValue();
      const qty = sheet.getRange(row, COL.QTY).getValue();
      const exec = sheet.getRange(row, COL.PRAS_EXEC).getValue();
      const orderId = ensureOrderIdForRow(sheet, row);

      const messageId = sendTelegramAssemblyCard(item, mat, week, qty, exec, orderId);
      if (messageId) {
        sheet.getRange(row, COL.TG_MESSAGE_ID).setValue(messageId);
        notifSentCell.setValue("SENT");
        logAction({
          source: "system",
          action: "SEND_NOTIFICATION",
          orderId,
          row,
          itemName: item,
          after: "SENT",
          user: "bot",
          comment: "message_id=" + messageId
        });
      }
    }
  } else if (pilka === STATUS_PAUSE) status = "⏸ Пилка на паузе";
  else if (kromka === STATUS_PAUSE) status = "⏸ Кромка на паузе";
  else if (pras === STATUS_PAUSE) status = "⏸ Присадка на паузе";
  else if (pras === "🔧 В работе (Лёха)" || pras === "🔧 В работе (Виталик)") status = "🔧 Присадка в процессе";
  else if (kromka === "🔪 В работе (Слава)" || kromka === "🔪 В работе (Сережа)") status = "🔪 Кромка в процессе";
  else if (pilka === "🔨 В работе") status = "🔨 Пилка в процессе";
  else if (pilka === "✅ Готово" && kromka === "✅ Готово") status = "⚙️ Ожидает присадку";
  else if (pilka === "✅ Готово") status = "🔪 Ожидает кромку";
  else status = "🟡 Ожидает начала";

  overallCell.setValue(status);
  updateShipmentNote(sheet, row, status);
  updateShipmentColor(sheet, row);
}

// ==================== EDIT TRIGGERS ====================
function onEdit(e) {
  if (!e || !e.source || !e.range) return;
  const sheet = e.source.getActiveSheet();
  if (!sheet) return;

  if (sheet.getName() === SHEETS.SHIPMENT) {
    handleShipmentMaterialEdit_(e);
    bumpBackendRevision_("shipment_edit");
    return;
  }
  if (sheet.getName() !== SHEETS.TRACK) return;

  const row = e.range.getRow();
  const col = e.range.getColumn();
  if (row < 2) return;

  const now = getMoscowTime();
  const val = e.range.getValue();

  if (col === COL.PILKA_STATUS) handlePilkaStatus(sheet, row, val, now);
  if (col === COL.KROMKA_STATUS) handleKromkaStatus(sheet, row, val, now);
  if (col === COL.PRAS_STATUS) handlePrasadkaStatus(sheet, row, val, now);
  if (col === COL.ASSEMBLY_STATUS) handleAssemblyStatus(sheet, row, val, now);
  if (col === COL.SHIPPED) handleShippedCheckbox(sheet, row, val);
  if (col === COL.CONSUME_SHEETS && val === true) {
    try {
      setScriptProp(PROP.PILKA_CONSUME_PENDING_ROW, row);
      promptMaterialAndConsumeForRow_(sheet, row);
    } catch (err) {
      console.log("Consume dialog from checkbox failed: " + err);
      SpreadsheetApp.getActive().toast("Откройте '🏭 Производство → 🧾 Списать листы (последняя пилка ✅)'", "Списание листов", 8);
    }
  }

  updateOverallStatus(sheet, row);
  bumpBackendRevision_("track_edit");
}

function onChange(e) {
  try {
    if (!e || !e.source) return;
    const changeType = String(e.changeType || "");
    // Срабатывает при добавлении строк/структурных изменениях, чтобы веб-клиенты увидели новый заказ.
    if (["INSERT_ROW", "REMOVE_ROW", "INSERT_GRID", "REMOVE_GRID", "EDIT"].includes(changeType)) {
      bumpBackendRevision_("change_" + changeType.toLowerCase());
    }
  } catch (_) {}
}

function ensureOnChangeTrigger_() {
  const ss = SpreadsheetApp.getActive();
  const exists = ScriptApp.getProjectTriggers().some((t) =>
