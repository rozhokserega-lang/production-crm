const MATERIALS_CFG = {
  COUNTED_COLOR: "#ffffff",
  START_ROW: 3,
  END_ROW: 300,
  ORDER_START_COL: 9,
  ORDER_END_COL: 52, // I:AZ
};

function calculateMaterialNeeds() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const sheet = ss.getSheetByName(SHEETS.SHIPMENT);
  if (!sheet) return;

  const rowCount = MATERIALS_CFG.END_ROW - MATERIALS_CFG.START_ROW + 1;
  const colCount = MATERIALS_CFG.ORDER_END_COL - MATERIALS_CFG.ORDER_START_COL + 1;
  const ordersRange = sheet.getRange(MATERIALS_CFG.START_ROW, MATERIALS_CFG.ORDER_START_COL, rowCount, colCount);
  const outputRange = sheet.getRange(MATERIALS_CFG.START_ROW, 2, rowCount, 1);
  const resultRange = sheet.getRange(MATERIALS_CFG.START_ROW, 3, rowCount, 1);

  const orders = ordersRange.getValues();
  const backgrounds = ordersRange.getBackgrounds();
  const outputs = outputRange.getValues();
  const countedColor = MATERIALS_CFG.COUNTED_COLOR.toLowerCase();

  const results = orders.map((rowValues, i) => {
    let totalOrders = 0;
    for (let j = 0; j < rowValues.length; j++) {
      const color = String(backgrounds[i][j] || "").toLowerCase();
      if (color === countedColor) totalOrders += Number(rowValues[j]) || 0;
    }
    const outputPerSheet = Number(outputs[i][0]) || 0;
    const sheetsNeeded = outputPerSheet > 0 ? Math.ceil(totalOrders / outputPerSheet) : 0;
    return [sheetsNeeded];
  });

  resultRange.setValues(results);
}

function calculateSelectedSheets() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const selection = ss.getSelection();
  const activeRangeList = selection && selection.getActiveRangeList();
  if (!activeRangeList) {
    SpreadsheetApp.getUi().alert("❌ Выделите диапазон ячеек!");
    return;
  }

  const ranges = activeRangeList.getRanges();
  if (!ranges || !ranges.length) {
    SpreadsheetApp.getUi().alert("❌ Выделите диапазон ячеек!");
    return;
  }

  const sheet = ss.getSheetByName(SHEETS.SHIPMENT);
  if (!sheet) return;

  const products = sheet.getRange("F3:F300").getValues();
  const outputs = sheet.getRange("B3:B300").getValues();
  const materials = sheet.getRange("A3:A300").getValues();

  let totalSheets = 0;
  let processedCells = 0;
  const materialTotals = {};
  let resultMessage = "📊 Расчет для выделенных ячеек:\n\n";

  for (const selectedRange of ranges) {
    const values = selectedRange.getValues();
    const selectedStartRow = selectedRange.getRow();
    for (let i = 0; i < values.length; i++) {
      for (let j = 0; j < values[i].length; j++) {
        const value = Number(values[i][j]) || 0;
        if (!value) continue;

        const rowIndex = selectedStartRow - 3 + i;
        if (rowIndex < 0 || rowIndex >= outputs.length) continue;

        const outputPerSheet = Number(outputs[rowIndex][0]) || 0;
        if (outputPerSheet <= 0) continue;

        const sheetsNeeded = Math.ceil(value / outputPerSheet);
        const materialName = String(materials[rowIndex][0] || "Неизвестный материал");
        const productName = String(products[rowIndex][0] || "Неизвестное изделие");

        materialTotals[materialName] = (materialTotals[materialName] || 0) + sheetsNeeded;
        totalSheets += sheetsNeeded;
        processedCells++;
        resultMessage += `📦 ${productName}\n${value} шт. → ${sheetsNeeded} лист(ов) ${materialName}\n\n`;
      }
    }
  }

  if (!processedCells) {
    SpreadsheetApp.getUi().alert("❌ Не найдено подходящих ячеек для расчета!\nПроверьте числовые значения.");
    return;
  }

  resultMessage += "✅ ОБЩЕЕ КОЛИЧЕСТВО:\n";
  Object.entries(materialTotals)
    .sort((a, b) => b[1] - a[1])
    .forEach(([material, count]) => {
      resultMessage += `• ${material}: ${count} лист(ов)\n`;
    });
  resultMessage += `\n📋 Обработано ячеек: ${processedCells}\n📄 Всего листов: ${totalSheets}`;
  SpreadsheetApp.getUi().alert(resultMessage);
}

function whatToOrderAccurate() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const sheet = ss.getSheetByName(SHEETS.SHIPMENT);
  if (!sheet) return;

  const materialsData = sheet.getRange("A3:A300").getValues();
  const shortageData = sheet.getRange("D3:D300").getValues();
  const materialShortages = {};

  for (let i = 0; i < materialsData.length; i++) {
    const materialName = String(materialsData[i][0] || "").trim();
    if (!materialName) continue;

    const shortageText = String(shortageData[i][0] || "");
    const shortageMatch = shortageText.match(/❌ Не хватает:\s*([\d.]+)/);
    if (!shortageMatch) continue;

    const shortageAmount = parseFloat(shortageMatch[1]);
    if (!(shortageAmount > 0)) continue;

    materialShortages[materialName] = Math.max(materialShortages[materialName] || 0, shortageAmount);
  }

  if (!Object.keys(materialShortages).length) {
    SpreadsheetApp.getUi().alert("✅ ВСЕГО ХВАТАЕТ!\n\nНехватки материалов не обнаружено.");
    return;
  }

  let totalSheets = 0;
  let resultMessage = "📋 ТОЧНЫЙ РАСЧЕТ ЗАКАЗА:\n\n";
  Object.entries(materialShortages)
    .sort((a, b) => b[1] - a[1])
    .forEach(([material, amount]) => {
      const sheetsToOrder = Math.ceil(amount);
      totalSheets += sheetsToOrder;
      resultMessage += `• ${material}: ${sheetsToOrder} лист(ов)\n`;
    });

  resultMessage += `\n📊 Всего материалов: ${Object.keys(materialShortages).length}`;
  resultMessage += `\n📦 Общее количество листов: ${totalSheets}`;
  SpreadsheetApp.getUi().alert(resultMessage);
}

function whatToOrder() {
  // Совместимость со старым пунктом меню/вызовами: используем точный расчет.
  return whatToOrderAccurate();
}

function setupTimeTrigger() {
