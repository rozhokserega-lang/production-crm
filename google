function refreshDashboard() {
  const track = getSheet(SHEETS.TRACK);
  const dash = getSheet(SHEETS.DASH);
  if (!track || !dash) return;

  const lastRow = track.getLastRow();
  if (lastRow < 2) {
    dash.getRange("B4:B7").setValues([[0], [0], [0], [0]]);
    dash.getRange("D4:F1000").clearContent();
    return;
  }

  const data = track.getRange(2, 1, lastRow - 1, COL.LAST).getValues();
  const now = getMoscowTime();
  const today = Utilities.formatDate(now, "GMT+3", "yyyy-MM-dd");

  let waiting = 0, assembledToday = 0, overdue = 0, cycleSum = 0, cycleCount = 0;
  const weekPlan = {}, weekFact = {};

  data.forEach(r => {
    const created = r[COL.CREATED_AT - 1];
    const week = String(r[COL.WEEK - 1] || "");
    const qty = Number(r[COL.QTY - 1] || 0);
    const overall = r[COL.OVERALL_STATUS - 1];
    const asm = r[COL.ASSEMBLY_STATUS - 1];
    const asmTime = r[COL.ASSEMBLY_TIME - 1];

    if (overall === "📦 Ожидает сборки") waiting++;
    if (week) weekPlan[week] = (weekPlan[week] || 0) + qty;
    if (asm === "✅ СОБРАНО" && week) weekFact[week] = (weekFact[week] || 0) + qty;

    if (asm === "✅ СОБРАНО" && asmTime) {
      const d = Utilities.formatDate(new Date(asmTime), "GMT+3", "yyyy-MM-dd");
      if (d === today) assembledToday++;
      if (created) {
        const hours = (new Date(asmTime) - new Date(created)) / 3600000;
        if (hours >= 0) { cycleSum += hours; cycleCount++; }
      }
    }

    if (created && asm !== "✅ СОБРАНО") {
      const age = (now - new Date(created)) / 3600000;
      if (age > 72) overdue++;
    }
  });

  const avg = cycleCount ? (cycleSum / cycleCount).toFixed(1) : "0.0";
  dash.getRange("B4:B7").setValues([[waiting], [assembledToday], [avg], [overdue]]);

  const weeks = Object.keys(weekPlan).filter(Boolean).sort((a, b) => Number(a) - Number(b));
  const rows = weeks.map(w => [w, weekPlan[w] || 0, weekFact[w] || 0]);
  dash.getRange("D4:F1000").clearContent();
  if (rows.length) dash.getRange(4, 4, rows.length, 3).setValues(rows);
}
function sendDailyPlanFactReport() {
  const track = getSheet(SHEETS.TRACK);
  if (!track) return;
  const lastRow = track.getLastRow();
  if (lastRow < 2) return;

  const data = track.getRange(2, 1, lastRow - 1, COL.LAST).getValues();
  const today = Utilities.formatDate(getMoscowTime(), "GMT+3", "yyyy-MM-dd");

  const factByWeek = {};
  let assembledCount = 0, assembledQty = 0;

  data.forEach(r => {
    const week = String(r[COL.WEEK - 1] || "");
    const qty = Number(r[COL.QTY - 1] || 0);
    const st = r[COL.ASSEMBLY_STATUS - 1];
    const at = r[COL.ASSEMBLY_TIME - 1];

    if (st === "✅ СОБРАНО" && at) {
      const d = Utilities.formatDate(new Date(at), "GMT+3", "yyyy-MM-dd");
      if (d === today) {
        assembledCount++; assembledQty += qty;
        if (week) factByWeek[week] = (factByWeek[week] || 0) + qty;
      }
    }
  });

  let msg = "📊 <b>План/Факт за день</b>\n📅 " + today + "\n\n";
  msg += "✅ Собрано заказов: " + assembledCount + "\n";
  msg += "📦 Собрано шт: " + assembledQty + "\n\nПо неделям:\n";

  const weeks = Object.keys(factByWeek).sort((a, b) => Number(a) - Number(b));
  if (!weeks.length) msg += "— нет сборок сегодня";
  else weeks.forEach(w => { msg += "• Неделя " + escapeHtml(w) + ": " + factByWeek[w] + " шт\n"; });

  sendTelegramMessage(msg);
}

